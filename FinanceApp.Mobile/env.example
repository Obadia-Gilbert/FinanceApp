# Copy to `.env`. Restart Expo after changes: npx expo start -c

EXPO_PUBLIC_API_URL=http://127.0.0.1:5022

# Google — https://console.cloud.google.com/apis/credentials
# Redirect: com.financeapp.mobile:/oauthredirect
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Facebook — https://developers.facebook.com/apps/ (App ID from Settings → Basic)
EXPO_PUBLIC_FACEBOOK_APP_ID=
