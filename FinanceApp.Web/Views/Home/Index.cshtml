@using System.Text.Json
@{
    ViewData["Title"] = L["Nav_Dashboard"].Value;
    var totalSpend = ViewBag.TotalSpend is decimal t ? t : 0m;
    var totalSpendUsd = ViewBag.TotalSpendUsd is decimal tu ? tu : 0m;
    var thisMonthSpendUsd = ViewBag.ThisMonthSpendUsd is decimal mu ? mu : 0m;
    var displayCurrency = ViewBag.DisplayCurrency as string ?? "TZS";
    var expenseCount = ViewBag.ExpenseCount ?? 0;
    var categoryCount = ViewBag.CategoryCount ?? 0;
    var thisMonthSpend = ViewBag.ThisMonthSpend is decimal m ? m : 0m;
    var chartLabels = ViewBag.ChartLabels ?? "[]";
    var chartData = ViewBag.ChartData ?? "[]";
    var chartCurrency = ViewBag.ChartCurrency as string ?? displayCurrency;
    var budgetAmount = ViewBag.BudgetAmount as decimal?;
    var budgetCurrency = ViewBag.BudgetCurrency as string ?? displayCurrency;
    var thisMonthSpendInBudgetCurrency = ViewBag.ThisMonthSpendInBudgetCurrency is decimal b ? b : 0m;
    var isOverBudget = ViewBag.IsOverBudget as bool? == true;
    var categoryBudgetAlerts = ViewBag.CategoryBudgetAlerts as IEnumerable<FinanceApp.Web.Models.CategoryBudgetAlertViewModel> ?? Enumerable.Empty<FinanceApp.Web.Models.CategoryBudgetAlertViewModel>();
    var userFirstName = ViewBag.UserFirstName as string ?? L["Generic_User"].Value;
    var totalBalance = ViewBag.TotalBalance is decimal tb ? tb : 0m;
    var monthlyIncome = ViewBag.MonthlyIncome is decimal mi ? mi : 0m;
    var momIncomeChange = ViewBag.MoMIncomeChange as decimal?;
    var momSpendChange = ViewBag.MoMSpendChange as decimal?;
    var activeBudgetsCount = ViewBag.ActiveBudgetsCount as int? ?? 0;
    var cashFlowSixMonthLabels = ViewBag.CashFlowSixMonthLabels ?? "[]";
    var cashFlowSixMonthData = ViewBag.CashFlowSixMonthData ?? "[]";
    var recentActivity = ViewBag.RecentActivity as IEnumerable<FinanceApp.Web.Models.RecentActivityViewModel> ?? Enumerable.Empty<FinanceApp.Web.Models.RecentActivityViewModel>();
    var cashFlowThisMonth = ViewBag.CashFlowThisMonth is decimal cf ? cf : (monthlyIncome - thisMonthSpend);
    var cashFlowMoMChange = ViewBag.CashFlowMoMChange as decimal?;
    var jsChartCashFlow = JsonSerializer.Serialize(L["Chart_CashFlow"].Value);
    var jsChartDailyExpenses = JsonSerializer.Serialize(L["Chart_DailyExpenses"].Value);
    var jsChartAmountAxis = JsonSerializer.Serialize(L["Chart_AmountAxis", chartCurrency].Value);
}

<div class="container-fluid dashboard-page">
    <div class="row mb-3 mb-md-4">
        <div class="col-12 d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
            <div>
                <h1 class="visually-hidden">@L["Nav_Dashboard"]</h1>
                <h2 class="visually-hidden">@L["Dash_OverviewHidden"]</h2>
                <p class="text-muted small mb-0">@L["Dash_WelcomeBack", userFirstName]</p>
            </div>
            <div class="d-flex gap-2">
                <span class="btn btn-outline-secondary btn-sm"><i class="bi bi-calendar3 me-1"></i>@L["Dash_ThisMonth"]</span>
            </div>
        </div>
    </div>

    @if (expenseCount == 0)
    {
        <div class="alert alert-info d-flex align-items-center mb-3 dashboard-alert" role="alert">
            <i class="bi bi-info-circle fs-4 me-3"></i>
            <div>
                <strong>@L["Dash_NoExpensesStrong"]</strong>
                <a asp-controller="Expense" asp-action="Index" class="alert-link">@L["Dash_NoExpensesLink"]</a>@L["Dash_NoExpensesTail"]
            </div>
        </div>
    }

    @if (isOverBudget)
    {
        <div class="alert alert-danger d-flex align-items-center mb-3 dashboard-alert" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
            <div class="flex-grow-1">
                <strong>@L["Dash_BudgetLimitStrong"]</strong>
                @L["Dash_BudgetSpentBody", thisMonthSpendInBudgetCurrency.ToString("N0"), budgetCurrency, budgetAmount?.ToString("N0") ?? "0", budgetCurrency]
                <a asp-controller="Budget" asp-action="Index" class="alert-link">@L["Dash_UpdateBudget"]</a>@L["Dash_OrReduceSpending"]
            </div>
        </div>
    }
    @foreach (var alert in categoryBudgetAlerts)
    {
        var isOver = alert.IsOver;
        var catName = alert.CategoryName ?? L["Generic_Category"].Value;
        var spent = alert.Spent;
        var budget = alert.Budget;
        var curr = alert.Currency ?? "TZS";
        <div class="alert @(isOver ? "alert-danger" : "alert-warning") d-flex align-items-center mb-3 dashboard-alert" role="alert">
            <i class="bi @(isOver ? "bi-exclamation-triangle-fill" : "bi-exclamation-circle") fs-4 me-3"></i>
            <div class="flex-grow-1">
                <strong>@catName</strong> @(isOver ? L["Dash_BudgetExceededLabel"].Value : L["Dash_BudgetNearLabel"].Value) <strong>@spent.ToString("N0") / @budget.ToString("N0") @curr</strong>.
                <a asp-controller="Budget" asp-action="Index" class="alert-link">@L["Dash_ManageBudgets"]</a>
            </div>
        </div>
    }
    @if (!budgetAmount.HasValue || budgetAmount == 0)
    {
        <div class="alert alert-secondary d-flex align-items-center mb-3 dashboard-alert" role="alert">
            <i class="bi bi-wallet2 fs-4 me-3"></i>
            <div>
                <strong>@L["Dash_SetMonthlyBudgetStrong"]</strong>@L["Dash_SetMonthlyBudgetTail"]
                <a asp-controller="Budget" asp-action="Index" class="alert-link">@L["Dash_SetBudgetLink"]</a>
            </div>
        </div>
    }

    <div class="row g-3 mb-4 dashboard-kpi-cards">
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-balance rounded-2"><i class="bi bi-wallet2"></i></div>
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_TotalBalance"]</p>
                    <p class="fw-bold mb-0 fs-5">@totalBalance.ToString("N2") <small class="fw-normal text-muted">@displayCurrency</small></p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-income rounded-2"><i class="bi bi-arrow-down-circle"></i></div>
                        @if (momIncomeChange.HasValue)
                        {
                            <span class="small @(momIncomeChange >= 0 ? "text-success" : "text-danger")"><i class="bi bi-graph-up-arrow"></i> @(momIncomeChange >= 0 ? "+" : "")@momIncomeChange.Value.ToString("F1")%</span>
                        }
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_MonthlyIncome"]</p>
                    <p class="fw-bold mb-0 fs-5">@monthlyIncome.ToString("N2") <small class="fw-normal text-muted">@displayCurrency</small></p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-expense rounded-2"><i class="bi bi-cart"></i></div>
                        @if (momSpendChange.HasValue)
                        {
                            <span class="small @(momSpendChange <= 0 ? "text-success" : "text-danger")"><i class="bi bi-graph-down-arrow"></i> @(momSpendChange >= 0 ? "+" : "")@momSpendChange.Value.ToString("F1")%</span>
                        }
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_MonthlyExpense"]</p>
                    <p class="fw-bold mb-0 fs-5">@thisMonthSpend.ToString("N2") <small class="fw-normal text-muted">@displayCurrency</small></p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-budget rounded-2"><i class="bi bi-pie-chart"></i></div>
                        <span class="small text-muted">@L["KPI_Stable"]</span>
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_ActiveBudgets"]</p>
                    <p class="fw-bold mb-0 fs-5">@activeBudgetsCount</p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-spend rounded-2"><i class="bi bi-currency-dollar"></i></div>
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_TotalSpend"]</p>
                    <p class="fw-bold mb-0 fs-5">@totalSpend.ToString("N0") <small class="fw-normal text-muted">@displayCurrency</small></p>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card dashboard-kpi-card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="dashboard-kpi-icon dashboard-kpi-icon-categories rounded-2"><i class="bi bi-tags"></i></div>
                    </div>
                    <p class="small text-muted text-uppercase mb-1 mt-2">@L["KPI_Categories"]</p>
                    <p class="fw-bold mb-0 fs-5">@categoryCount</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">@L["Dash_MonthlyCashFlow"]</h5>
                        <div class="dropdown">
                            <button class="btn btn-link btn-sm p-0 text-secondary" type="button" data-bs-toggle="dropdown" aria-label="@L["Dash_OptionsAria"]"><i class="bi bi-three-dots-vertical"></i></button>
                            <ul class="dropdown-menu dropdown-menu-end"><li><a class="dropdown-item" asp-controller="Budget" asp-action="Index">@L["Dash_ViewBudget"]</a></li></ul>
                        </div>
                    </div>
                    <p class="fw-bold fs-4 mb-1">@cashFlowThisMonth.ToString("N2") <small class="fw-normal text-muted">@displayCurrency</small></p>
                    @if (cashFlowMoMChange.HasValue)
                    {
                        <p class="small @(cashFlowMoMChange >= 0 ? "text-success" : "text-danger") mb-3">@L["Dash_PctVsLastMonth", (cashFlowMoMChange >= 0 ? "+" : "") + cashFlowMoMChange.Value.ToString("F0")]</p>
                    }
                    else
                    {
                        <p class="small text-muted mb-3">@L["Dash_IncomeMinusExpenses"]</p>
                    }
                    <div class="dashboard-bar-chart-wrap" style="height: 140px;">
                        <canvas id="cashFlowChart" height="140"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">@L["Dash_RecentTransactions"]</h5>
                        <a asp-controller="Transaction" asp-action="Index" class="btn btn-link btn-sm p-0 text-decoration-none">@L["Dash_ViewAll"]</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="text-muted small text-uppercase">@L["Table_Date"]</th>
                                    <th class="text-muted small text-uppercase">@L["Table_Category"]</th>
                                    <th class="text-muted small text-uppercase text-end">@L["Table_Amount"]</th>
                                    <th class="text-muted small text-uppercase" style="width: 40px;">@L["Table_Actions"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recentActivity.Any())
                                {
                                    @foreach (var a in recentActivity.Take(5))
                                    {
                                        <tr>
                                            <td class="small">@a.Date.ToString("MMM d, yyyy")</td>
                                            <td>
                                                <span class="d-inline-flex align-items-center gap-1">
                                                    <span class="rounded-circle d-inline-block @(a.IsIncome ? "bg-success" : "bg-danger")" style="width: 8px; height: 8px;" aria-hidden="true"></span>
                                                    @a.CategoryName
                                                </span>
                                            </td>
                                            <td class="text-end fw-semibold @(a.IsIncome ? "text-success" : "text-danger")">@(a.IsIncome ? "+" : "-")@Math.Abs(a.Amount).ToString("N2") @a.Currency</td>
                                            <td><button type="button" class="btn btn-link btn-sm p-0 text-secondary" aria-label="@L["Table_Actions"]"><i class="bi bi-three-dots-vertical"></i></button></td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr><td colspan="4" class="text-muted small text-center py-3">@L["Dash_NoRecentTx"] <a asp-controller="Expense" asp-action="Index">@L["Dash_AddExpense"]</a>@L["Dash_Or"]<a asp-controller="Transaction" asp-action="Create">@L["Dash_NewTransaction"]</a>.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3 mt-md-4 mb-3">
        <div class="col-12">
            <div class="card expense-trend-card border-0 shadow-sm">
                <div class="card-body py-3">
                    <h5 class="card-title mb-2">@L["Dash_ExpenseTrendTitle", chartCurrency]</h5>
                    @if (expenseCount == 0)
                    {
                        <p class="text-muted mb-0">@L["Dash_AddExpensesChartHint"]</p>
                    }
                    else
                    {
                        <div class="expense-chart-wrap">
                            <canvas id="expenseChart" height="80"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function() {
            function isDark() { return document.body.getAttribute('data-theme') === 'dark'; }
            function chartColors() {
                if (isDark()) {
                    return { border: '#4da6ff', fill: 'rgba(77, 166, 255, 0.15)', grid: 'rgba(255,255,255,0.1)', text: '#e1e1e1', bar: 'rgba(77, 166, 255, 0.8)', barCurrent: '#4da6ff' };
                }
                return { border: '#0d6efd', fill: 'rgba(13, 110, 253, 0.1)', grid: 'rgba(0,0,0,0.1)', text: '#212529', bar: 'rgba(13, 110, 253, 0.5)', barCurrent: '#0d6efd' };
            }

            var cashFlowCanvas = document.getElementById('cashFlowChart');
            if (cashFlowCanvas) {
                var cfLabels = @Html.Raw(cashFlowSixMonthLabels);
                var cfData = @Html.Raw(cashFlowSixMonthData);
                var colors = chartColors();
                var barColors = cfData.map(function(_, i) { return i === cfData.length - 1 ? colors.barCurrent : colors.bar; });
                new Chart(cashFlowCanvas.getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels: cfLabels,
                        datasets: [{ label: @Html.Raw(jsChartCashFlow), data: cfData, backgroundColor: barColors, borderColor: barColors, borderWidth: 1 }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { ticks: { color: colors.text, maxRotation: 0 }, grid: { display: false } },
                            y: { beginAtZero: true, ticks: { color: colors.text }, grid: { color: colors.grid } }
                        }
                    }
                });
            }

            var canvas = document.getElementById('expenseChart');
            if (!canvas) return;
            var ctx = canvas.getContext('2d');
            var labels = @Html.Raw(chartLabels);
            var data = @Html.Raw(chartData);
            var colors = chartColors();
            var chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: @Html.Raw(jsChartDailyExpenses),
                        data: data,
                        borderColor: colors.border,
                        backgroundColor: colors.fill,
                        borderWidth: 2,
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: colors.border,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: true, position: 'top', labels: { color: colors.text } }
                    },
                    scales: {
                        x: { ticks: { color: colors.text }, grid: { color: colors.grid } },
                        y: {
                            beginAtZero: true,
                            ticks: { color: colors.text },
                            grid: { color: colors.grid },
                            title: { display: true, text: @Html.Raw(jsChartAmountAxis), color: colors.text }
                        }
                    }
                }
            });

            document.getElementById('themeToggle')?.addEventListener('click', function() {
                setTimeout(function() {
                    var c = chartColors();
                    if (chart && chart.options && chart.options.plugins) {
                        chart.options.plugins.legend.labels.color = c.text;
                        chart.options.scales.x.ticks.color = c.text;
                        chart.options.scales.x.grid.color = c.grid;
                        chart.options.scales.y.ticks.color = c.text;
                        chart.options.scales.y.grid.color = c.grid;
                        chart.options.scales.y.title.color = c.text;
                        chart.data.datasets[0].borderColor = c.border;
                        chart.data.datasets[0].backgroundColor = c.fill;
                        chart.data.datasets[0].pointBackgroundColor = c.border;
                        chart.update();
                    }
                }, 50);
            });
        })();
    </script>
}
