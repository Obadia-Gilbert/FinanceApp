@{
    ViewData["Title"] = "Privacy Policy";
}

<style>
/* ---- Privacy page layout ---- */
.privacy-hero {
    background: linear-gradient(135deg, #EFF6FF 0%, #F9FAFB 60%, #F0FDF4 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem 2rem;
    margin-bottom: 2rem;
}
.privacy-hero .badge-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #DBEAFE;
    color: #1D4ED8;
    border-radius: 2rem;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
}
.privacy-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.625rem;
}
.privacy-hero .lead {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0;
}

/* ---- Sticky TOC sidebar ---- */
.privacy-toc {
    position: sticky;
    top: 56px;
}
.privacy-toc .toc-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    margin-bottom: 0.5rem;
    padding: 0 0.5rem;
}
.privacy-toc a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    line-height: 1.4;
}
.privacy-toc a:hover,
.privacy-toc a.active {
    background: var(--color-bg-hover);
    color: var(--color-brand);
}
.privacy-toc a .toc-num {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-subtle);
    min-width: 16px;
}

/* ---- Section cards ---- */
.privacy-section {
    scroll-margin-top: 72px;
    margin-bottom: 1.5rem;
}
.privacy-section .section-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
}
.privacy-section .section-icon {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
}
.privacy-section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
}
.privacy-section p,
.privacy-section li {
    font-size: 0.9rem;
    color: var(--color-text-body);
    line-height: 1.7;
}
.privacy-section ul {
    padding-left: 1.25rem;
    margin-bottom: 0;
}
.privacy-section ul li {
    margin-bottom: 0.25rem;
}
.privacy-section ul li::marker {
    color: var(--color-brand);
}

/* Highlight box */
.privacy-highlight {
    background: #EFF6FF;
    border-left: 3px solid var(--color-brand);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 0.75rem 1rem;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: #1E40AF;
}

/* Contact card */
.privacy-contact-card {
    background: linear-gradient(135deg, #F0FDF4, #ECFDF5);
    border: 1px solid #BBF7D0;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
}
.privacy-contact-card .contact-icon {
    width: 48px;
    height: 48px;
    background: #DCFCE7;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: #16A34A;
    margin-bottom: 0.75rem;
}

@@media (max-width: 767.98px) {
    .privacy-hero { padding: 1.5rem 1.25rem; }
    .privacy-hero h1 { font-size: 1.375rem; }
    .privacy-toc { display: none; }
}
</style>

<!-- Hero Header -->
<div class="privacy-hero">
    <div class="badge-updated">
        <i class="bi bi-calendar3"></i> Last updated: March 1, 2026
    </div>
    <h1>Privacy Policy</h1>
    <p class="lead">We believe your financial data belongs to you. This policy explains clearly what we collect, how we use it, and the controls you have over it.</p>
</div>

<div class="row g-4">

    <!-- Sticky TOC — desktop sidebar -->
    <div class="col-lg-3 d-none d-lg-block">
        <nav class="privacy-toc" aria-label="Policy sections">
            <p class="toc-title">Contents</p>
            <a href="#s1"><span class="toc-num">01</span> Overview</a>
            <a href="#s2"><span class="toc-num">02</span> Information We Collect</a>
            <a href="#s3"><span class="toc-num">03</span> How We Use Your Data</a>
            <a href="#s4"><span class="toc-num">04</span> Storage &amp; Security</a>
            <a href="#s5"><span class="toc-num">05</span> Data Retention</a>
            <a href="#s6"><span class="toc-num">06</span> Your Rights</a>
            <a href="#s7"><span class="toc-num">07</span> Third-Party Services</a>
            <a href="#s8"><span class="toc-num">08</span> Cookies</a>
            <a href="#s9"><span class="toc-num">09</span> Policy Changes</a>
            <a href="#s10"><span class="toc-num">10</span> Contact Us</a>
        </nav>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">

        <!-- 01 Overview -->
        <div class="card shadow-sm privacy-section" id="s1">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-shield-check"></i></span>
                    <h2>01 &nbsp;Overview</h2>
                </div>
                <p>FinanceApp is a personal finance management application. We are committed to protecting your privacy and handling your data with care, transparency, and respect. This policy applies to all users of FinanceApp and describes how we collect, use, and safeguard your information when you use our service.</p>
                <p>By using FinanceApp you agree to the practices described in this policy. If you do not agree, please discontinue use of the application.</p>
                <div class="privacy-highlight">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>Short version:</strong> We collect only what we need to run the app. We never sell your data. You control your data.
                </div>
            </div>
        </div>

        <!-- 02 Information We Collect -->
        <div class="card shadow-sm privacy-section" id="s2">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-info bg-opacity-10 text-info"><i class="bi bi-collection"></i></span>
                    <h2>02 &nbsp;Information We Collect</h2>
                </div>
                <p>We collect the minimum information necessary to provide the service:</p>
                <p class="fw-600 mb-1" style="font-size:.875rem;">Account information</p>
                <ul>
                    <li>Name, email address, and password (stored as a secure hash — we never store plain-text passwords)</li>
                    <li>Optional profile photo you upload</li>
                    <li>Subscription plan and assignment date</li>
                </ul>
                <p class="fw-600 mb-1 mt-3" style="font-size:.875rem;">Financial data you enter</p>
                <ul>
                    <li>Expense records: description, amount, currency, date, category</li>
                    <li>Account records: name, type, currency, balance</li>
                    <li>Transaction records: type, amount, date, category, notes</li>
                    <li>Budget settings and category configurations</li>
                    <li>Supporting documents and receipt files you attach</li>
                </ul>
                <p class="fw-600 mb-1 mt-3" style="font-size:.875rem;">Technical data</p>
                <ul>
                    <li>Authentication tokens and session identifiers</li>
                    <li>Anti-forgery tokens for security</li>
                </ul>
            </div>
        </div>

        <!-- 03 How We Use Your Data -->
        <div class="card shadow-sm privacy-section" id="s3">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-gear"></i></span>
                    <h2>03 &nbsp;How We Use Your Data</h2>
                </div>
                <p>Your data is used exclusively to operate and improve FinanceApp. Specifically, we use it to:</p>
                <ul>
                    <li>Authenticate you and maintain a secure session</li>
                    <li>Display your financial records, summaries, and budgets</li>
                    <li>Generate Excel exports of your data on demand</li>
                    <li>Serve uploaded receipt and document files back to you</li>
                    <li>Send security-related emails (e.g. password reset) when you request them</li>
                    <li>Improve application performance and fix bugs</li>
                </ul>
                <p class="mt-2 mb-0"><strong>We do not</strong> use your financial data for advertising, profiling, or selling to third parties.</p>
            </div>
        </div>

        <!-- 04 Storage & Security -->
        <div class="card shadow-sm privacy-section" id="s4">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-success bg-opacity-10 text-success"><i class="bi bi-lock"></i></span>
                    <h2>04 &nbsp;Storage &amp; Security</h2>
                </div>
                <p>We take security seriously and have implemented multiple layers of protection:</p>
                <ul>
                    <li><strong>Passwords</strong> are hashed using ASP.NET Core Identity's industry-standard algorithm (PBKDF2 with HMAC-SHA256) — the original password is never stored</li>
                    <li><strong>Authentication</strong> uses secure, HTTP-only session cookies with anti-forgery token validation on every state-changing request</li>
                    <li><strong>Database</strong> is isolated per deployment — your data is not commingled with other users' data without access controls</li>
                    <li><strong>Uploaded files</strong> are stored server-side and accessed only by the authenticated owner</li>
                    <li><strong>HTTPS</strong> is enforced in production to encrypt all data in transit</li>
                    <li><strong>Soft deletes</strong> are used — when you delete a record it is flagged as deleted and excluded from queries, providing a safety net against accidental loss</li>
                </ul>
            </div>
        </div>

        <!-- 05 Data Retention -->
        <div class="card shadow-sm privacy-section" id="s5">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-clock-history"></i></span>
                    <h2>05 &nbsp;Data Retention</h2>
                </div>
                <p>Your data is retained for as long as your account remains active. When you delete your account:</p>
                <ul>
                    <li>All financial records associated with your account are permanently removed</li>
                    <li>Uploaded files and receipts are deleted from the server</li>
                    <li>Account credentials are purged from the identity store</li>
                </ul>
                <p>You can request deletion of specific records at any time from within the application using the delete actions on each record.</p>
            </div>
        </div>

        <!-- 06 Your Rights -->
        <div class="card shadow-sm privacy-section" id="s6">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-check"></i></span>
                    <h2>06 &nbsp;Your Rights &amp; Controls</h2>
                </div>
                <p>You have full control over your data within FinanceApp:</p>
                <ul>
                    <li><strong>Access</strong> — view all your financial records, account details, and uploaded documents at any time</li>
                    <li><strong>Correction</strong> — edit any record through the application's edit functions</li>
                    <li><strong>Deletion</strong> — delete any record, document, or your entire account</li>
                    <li><strong>Export</strong> — download your expense data as an Excel file at any time via the Export button on the Expenses page</li>
                    <li><strong>Profile management</strong> — update your name, email, and profile photo from the Edit Profile page</li>
                </ul>
                <p class="mb-0">If you need assistance exercising any of these rights, please contact us using the information in Section 10.</p>
            </div>
        </div>

        <!-- 07 Third-Party Services -->
        <div class="card shadow-sm privacy-section" id="s7">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-box-arrow-up-right"></i></span>
                    <h2>07 &nbsp;Third-Party Services</h2>
                </div>
                <p>FinanceApp loads the following third-party resources to power the interface:</p>
                <ul>
                    <li><strong>Google Fonts</strong> (fonts.googleapis.com) — loads the Inter typeface for display; Google may log the font request</li>
                    <li><strong>Bootstrap Icons CDN</strong> (cdn.jsdelivr.net) — loads icon fonts; jsDelivr may log the asset request</li>
                    <li><strong>DataTables CDN</strong> (cdn.jsdelivr.net) — loads table enhancement scripts</li>
                </ul>
                <p class="mb-0">These services receive only your IP address and browser headers as part of standard HTTP requests. No financial data is transmitted to any of these services. We do not use analytics tools, advertising networks, or any tracking pixels.</p>
            </div>
        </div>

        <!-- 08 Cookies -->
        <div class="card shadow-sm privacy-section" id="s8">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-info bg-opacity-10 text-info"><i class="bi bi-browser-chrome"></i></span>
                    <h2>08 &nbsp;Cookies</h2>
                </div>
                <p>FinanceApp uses a minimal set of cookies, all strictly necessary for the application to function:</p>
                <div class="table-responsive mt-2">
                    <table class="table table-sm table-bordered mb-0" style="font-size:.85rem;">
                        <thead class="table-light">
                            <tr>
                                <th>Cookie</th>
                                <th>Purpose</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>.AspNetCore.Cookies</code></td>
                                <td>Maintains your authenticated session</td>
                                <td>Session / sliding expiry</td>
                            </tr>
                            <tr>
                                <td><code>.AspNetCore.Antiforgery.*</code></td>
                                <td>Prevents cross-site request forgery (CSRF) attacks</td>
                                <td>Session</td>
                            </tr>
                            <tr>
                                <td><code>theme</code> (localStorage)</td>
                                <td>Remembers your light/dark mode preference</td>
                                <td>Persistent (local storage)</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <p class="mt-2 mb-0">We do not use advertising cookies, tracking cookies, or any cookies from third-party ad networks.</p>
            </div>
        </div>

        <!-- 09 Policy Changes -->
        <div class="card shadow-sm privacy-section" id="s9">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-pencil-square"></i></span>
                    <h2>09 &nbsp;Changes to This Policy</h2>
                </div>
                <p>We may update this policy from time to time to reflect changes in the application or applicable law. When we do:</p>
                <ul>
                    <li>The "Last updated" date at the top of this page will be revised</li>
                    <li>Significant changes will be communicated through the application</li>
                </ul>
                <p class="mb-0">Continued use of FinanceApp after a policy update constitutes acceptance of the revised policy. We encourage you to review this page periodically.</p>
            </div>
        </div>

        <!-- 10 Contact -->
        <div class="privacy-section" id="s10">
            <div class="privacy-contact-card">
                <div class="contact-icon">
                    <i class="bi bi-envelope-open"></i>
                </div>
                <h2 style="font-size:1.0625rem; margin-bottom:.375rem;">10 &nbsp;Contact Us</h2>
                <p class="text-muted mb-3" style="font-size:.9rem;">Have questions, concerns, or a data request? We're here to help.</p>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <a href="mailto:privacy@financeapp.local" class="btn btn-success btn-sm">
                        <i class="bi bi-envelope me-1"></i> privacy@financeapp.local
                    </a>
                    <a asp-area="" asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-person-gear me-1"></i> Manage your profile
                    </a>
                </div>
                <p class="text-muted mt-3 mb-0" style="font-size:.8rem;">
                    We aim to respond to all privacy-related inquiries within 5 business days.
                </p>
            </div>
        </div>

    </div><!-- /col -->
</div><!-- /row -->

@section Scripts {
<script>
(function () {
    // Highlight active TOC link on scroll
    const sections = document.querySelectorAll('.privacy-section[id]');
    const tocLinks = document.querySelectorAll('.privacy-toc a');
    if (!sections.length || !tocLinks.length) return;

    function onScroll() {
        let current = '';
        sections.forEach(s => {
            if (window.scrollY >= s.offsetTop - 80) current = s.id;
        });
        tocLinks.forEach(a => {
            a.classList.toggle('active', a.getAttribute('href') === '#' + current);
        });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
})();
</script>
}
