@{
    ViewData["Title"] = L["Priv_Title"].Value;
}

<style>
/* ---- Privacy page layout ---- */
.privacy-hero {
    background: linear-gradient(135deg, #EFF6FF 0%, #F9FAFB 60%, #F0FDF4 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem 2rem;
    margin-bottom: 2rem;
}
.privacy-hero .badge-updated {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #DBEAFE;
    color: #1D4ED8;
    border-radius: 2rem;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
}
.privacy-hero h1 {
    font-size: 1.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-bottom: 0.625rem;
}
.privacy-hero .lead {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0;
}

/* ---- Sticky TOC sidebar ---- */
.privacy-toc {
    position: sticky;
    top: 56px;
}
.privacy-toc .toc-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-subtle);
    margin-bottom: 0.5rem;
    padding: 0 0.5rem;
}
.privacy-toc a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    line-height: 1.4;
}
.privacy-toc a:hover,
.privacy-toc a.active {
    background: var(--color-bg-hover);
    color: var(--color-brand);
}
.privacy-toc a .toc-num {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-text-subtle);
    min-width: 16px;
}

/* ---- Section cards ---- */
.privacy-section {
    scroll-margin-top: 72px;
    margin-bottom: 1.5rem;
}
.privacy-section .section-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
}
.privacy-section .section-icon {
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
}
.privacy-section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
}
.privacy-section p,
.privacy-section li {
    font-size: 0.9rem;
    color: var(--color-text-body);
    line-height: 1.7;
}
.privacy-section ul {
    padding-left: 1.25rem;
    margin-bottom: 0;
}
.privacy-section ul li {
    margin-bottom: 0.25rem;
}
.privacy-section ul li::marker {
    color: var(--color-brand);
}

/* Highlight box */
.privacy-highlight {
    background: #EFF6FF;
    border-left: 3px solid var(--color-brand);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 0.75rem 1rem;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: #1E40AF;
}

/* Contact card */
.privacy-contact-card {
    background: linear-gradient(135deg, #F0FDF4, #ECFDF5);
    border: 1px solid #BBF7D0;
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
}
.privacy-contact-card .contact-icon {
    width: 48px;
    height: 48px;
    background: #DCFCE7;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: #16A34A;
    margin-bottom: 0.75rem;
}

@@media (max-width: 767.98px) {
    .privacy-hero { padding: 1.5rem 1.25rem; }
    .privacy-hero h1 { font-size: 1.375rem; }
    .privacy-toc { display: none; }
}
</style>

<!-- Hero Header -->
<div class="privacy-hero">
    <div class="badge-updated">
        <i class="bi bi-calendar3"></i> @L["Priv_BadgeUpdated"]
    </div>
    <h1>@L["Priv_Title"]</h1>
    <p class="lead">@L["Priv_HeroLead"]</p>
</div>

<div class="row g-4">

    <!-- Sticky TOC — desktop sidebar -->
    <div class="col-lg-3 d-none d-lg-block">
        <nav class="privacy-toc" aria-label="@L["Priv_TocNavAria"]">
            <p class="toc-title">@L["Priv_TocContents"]</p>
            <a href="#s1"><span class="toc-num">01</span> @L["Priv_Toc01"]</a>
            <a href="#s2"><span class="toc-num">02</span> @L["Priv_Toc02"]</a>
            <a href="#s3"><span class="toc-num">03</span> @L["Priv_Toc03"]</a>
            <a href="#s4"><span class="toc-num">04</span> @L["Priv_Toc04"]</a>
            <a href="#s5"><span class="toc-num">05</span> @L["Priv_Toc05"]</a>
            <a href="#s6"><span class="toc-num">06</span> @L["Priv_Toc06"]</a>
            <a href="#s7"><span class="toc-num">07</span> @L["Priv_Toc07"]</a>
            <a href="#s8"><span class="toc-num">08</span> @L["Priv_Toc08"]</a>
            <a href="#s9"><span class="toc-num">09</span> @L["Priv_Toc09"]</a>
            <a href="#s10"><span class="toc-num">10</span> @L["Priv_Toc10"]</a>
        </nav>
    </div>

    <!-- Main content -->
    <div class="col-lg-9">

        <!-- 01 Overview -->
        <div class="card shadow-sm privacy-section" id="s1">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-shield-check"></i></span>
                    <h2>@L["Priv_S1_H2"]</h2>
                </div>
                <p>@L["Priv_S1_P1"]</p>
                <p>@L["Priv_S1_P2"]</p>
                <div class="privacy-highlight">
                    <i class="bi bi-info-circle me-2"></i>
                    @L["Priv_S1_Highlight"]
                </div>
            </div>
        </div>

        <!-- 02 Information We Collect -->
        <div class="card shadow-sm privacy-section" id="s2">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-info bg-opacity-10 text-info"><i class="bi bi-collection"></i></span>
                    <h2>@L["Priv_S2_H2"]</h2>
                </div>
                <p>@L["Priv_S2_P1"]</p>
                <p class="fw-600 mb-1" style="font-size:.875rem;">@L["Priv_S2_AccountHdr"]</p>
                <ul>
                    <li>@L["Priv_S2_A1"]</li>
                    <li>@L["Priv_S2_A2"]</li>
                    <li>@L["Priv_S2_A3"]</li>
                </ul>
                <p class="fw-600 mb-1 mt-3" style="font-size:.875rem;">@L["Priv_S2_FinancialHdr"]</p>
                <ul>
                    <li>@L["Priv_S2_F1"]</li>
                    <li>@L["Priv_S2_F2"]</li>
                    <li>@L["Priv_S2_F3"]</li>
                    <li>@L["Priv_S2_F4"]</li>
                    <li>@L["Priv_S2_F5"]</li>
                </ul>
                <p class="fw-600 mb-1 mt-3" style="font-size:.875rem;">@L["Priv_S2_TechHdr"]</p>
                <ul>
                    <li>@L["Priv_S2_T1"]</li>
                    <li>@L["Priv_S2_T2"]</li>
                </ul>
            </div>
        </div>

        <!-- 03 How We Use Your Data -->
        <div class="card shadow-sm privacy-section" id="s3">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-gear"></i></span>
                    <h2>@L["Priv_S3_H2"]</h2>
                </div>
                <p>@L["Priv_S3_P1"]</p>
                <ul>
                    <li>@L["Priv_S3_L1"]</li>
                    <li>@L["Priv_S3_L2"]</li>
                    <li>@L["Priv_S3_L3"]</li>
                    <li>@L["Priv_S3_L4"]</li>
                    <li>@L["Priv_S3_L5"]</li>
                    <li>@L["Priv_S3_L6"]</li>
                </ul>
                <p class="mt-2 mb-0">@L["Priv_S3_P2"]</p>
            </div>
        </div>

        <!-- 04 Storage & Security -->
        <div class="card shadow-sm privacy-section" id="s4">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-success bg-opacity-10 text-success"><i class="bi bi-lock"></i></span>
                    <h2>@L["Priv_S4_H2"]</h2>
                </div>
                <p>@L["Priv_S4_P1"]</p>
                <ul>
                    <li>@L["Priv_S4_L1"]</li>
                    <li>@L["Priv_S4_L2"]</li>
                    <li>@L["Priv_S4_L3"]</li>
                    <li>@L["Priv_S4_L4"]</li>
                    <li>@L["Priv_S4_L5"]</li>
                    <li>@L["Priv_S4_L6"]</li>
                </ul>
            </div>
        </div>

        <!-- 05 Data Retention -->
        <div class="card shadow-sm privacy-section" id="s5">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-clock-history"></i></span>
                    <h2>@L["Priv_S5_H2"]</h2>
                </div>
                <p>@L["Priv_S5_P1"]</p>
                <ul>
                    <li>@L["Priv_S5_L1"]</li>
                    <li>@L["Priv_S5_L2"]</li>
                    <li>@L["Priv_S5_L3"]</li>
                </ul>
                <p>@L["Priv_S5_P2"]</p>
            </div>
        </div>

        <!-- 06 Your Rights -->
        <div class="card shadow-sm privacy-section" id="s6">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-person-check"></i></span>
                    <h2>@L["Priv_S6_H2"]</h2>
                </div>
                <p>@L["Priv_S6_P1"]</p>
                <ul>
                    <li>@L["Priv_S6_L1"]</li>
                    <li>@L["Priv_S6_L2"]</li>
                    <li>@L["Priv_S6_L3"]</li>
                    <li>@L["Priv_S6_L4"]</li>
                    <li>@L["Priv_S6_L5"]</li>
                </ul>
                <p class="mb-0">@L["Priv_S6_P2"]</p>
            </div>
        </div>

        <!-- 07 Third-Party Services -->
        <div class="card shadow-sm privacy-section" id="s7">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-box-arrow-up-right"></i></span>
                    <h2>@L["Priv_S7_H2"]</h2>
                </div>
                <p>@L["Priv_S7_P1"]</p>
                <ul>
                    <li>@L["Priv_S7_L1"]</li>
                    <li>@L["Priv_S7_L2"]</li>
                    <li>@L["Priv_S7_L3"]</li>
                </ul>
                <p class="mb-0">@L["Priv_S7_P2"]</p>
            </div>
        </div>

        <!-- 08 Cookies -->
        <div class="card shadow-sm privacy-section" id="s8">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-info bg-opacity-10 text-info"><i class="bi bi-browser-chrome"></i></span>
                    <h2>@L["Priv_S8_H2"]</h2>
                </div>
                <p>@L["Priv_S8_P1"]</p>
                <div class="table-responsive mt-2">
                    <table class="table table-sm table-bordered mb-0" style="font-size:.85rem;">
                        <thead class="table-light">
                            <tr>
                                <th>@L["Priv_TableCookie"]</th>
                                <th>@L["Priv_TablePurpose"]</th>
                                <th>@L["Priv_TableDuration"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>.AspNetCore.Cookies</code></td>
                                <td>@L["Priv_Cookie_R1C2"]</td>
                                <td>@L["Priv_Cookie_R1C3"]</td>
                            </tr>
                            <tr>
                                <td><code>.AspNetCore.Antiforgery.*</code></td>
                                <td>@L["Priv_Cookie_R2C2"]</td>
                                <td>@L["Priv_Cookie_R2C3"]</td>
                            </tr>
                            <tr>
                                <td><code>theme</code> @L["Priv_Cookie_R3C1"]</td>
                                <td>@L["Priv_Cookie_R3C2"]</td>
                                <td>@L["Priv_Cookie_R3C3"]</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <p class="mt-2 mb-0">@L["Priv_S8_P2"]</p>
            </div>
        </div>

        <!-- 09 Policy Changes -->
        <div class="card shadow-sm privacy-section" id="s9">
            <div class="card-body">
                <div class="section-header">
                    <span class="section-icon bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-pencil-square"></i></span>
                    <h2>@L["Priv_S9_H2"]</h2>
                </div>
                <p>@L["Priv_S9_P1"]</p>
                <ul>
                    <li>@L["Priv_S9_L1"]</li>
                    <li>@L["Priv_S9_L2"]</li>
                </ul>
                <p class="mb-0">@L["Priv_S9_P2"]</p>
            </div>
        </div>

        <!-- 10 Contact -->
        <div class="privacy-section" id="s10">
            <div class="privacy-contact-card">
                <div class="contact-icon">
                    <i class="bi bi-envelope-open"></i>
                </div>
                <h2 style="font-size:1.0625rem; margin-bottom:.375rem;">@L["Priv_S10_H2"]</h2>
                <p class="text-muted mb-3" style="font-size:.9rem;">@L["Priv_S10_P1"]</p>
                <div class="d-flex flex-wrap justify-content-center gap-2">
                    <a href="mailto:privacy@financeapp.local" class="btn btn-success btn-sm">
                        <i class="bi bi-envelope me-1"></i> privacy@financeapp.local
                    </a>
                    <a asp-area="" asp-controller="Profile" asp-action="Edit" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-person-gear me-1"></i> @L["Acc_ManageProfile"]
                    </a>
                </div>
                <p class="text-muted mt-3 mb-0" style="font-size:.8rem;">
                    @L["Priv_S10_P2"]
                </p>
            </div>
        </div>

    </div><!-- /col -->
</div><!-- /row -->

@section Scripts {
<script>
(function () {
    // Highlight active TOC link on scroll
    const sections = document.querySelectorAll('.privacy-section[id]');
    const tocLinks = document.querySelectorAll('.privacy-toc a');
    if (!sections.length || !tocLinks.length) return;

    function onScroll() {
        let current = '';
        sections.forEach(s => {
            if (window.scrollY >= s.offsetTop - 80) current = s.id;
        });
        tocLinks.forEach(a => {
            a.classList.toggle('active', a.getAttribute('href') === '#' + current);
        });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
})();
</script>
}
