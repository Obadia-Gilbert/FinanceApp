@model FinanceApp.Application.Common.PagedResult<FinanceApp.Web.Models.CategoryViewModel>
@using System.Text.Json
@{
    ViewData["Title"] = L["Cat_PageTitle"].Value;
    var jsCatDtSearch = JsonSerializer.Serialize(L["Cat_DTSearchPlaceholder"].Value);
    var jsCatDtInfo = JsonSerializer.Serialize(L["Cat_DTInfo"].Value);
    var jsCatDtFiltered = JsonSerializer.Serialize(L["Cat_DTInfoFiltered"].Value);
    var jsCatDtLength = JsonSerializer.Serialize(L["Cat_DTLengthMenu"].Value);
    var jsCatErrLoad = JsonSerializer.Serialize(L["Exp_ErrLoadForm"].Value);
    var jsCatErrEdit = JsonSerializer.Serialize(L["Exp_ErrLoadEdit"].Value);
    var jsCatErrDelete = JsonSerializer.Serialize(L["Exp_ErrLoadDelete"].Value);
    var jsCatAddLabel = JsonSerializer.Serialize(L["Cat_OffcanvasAdd"].Value);
    var jsCatEditLabel = JsonSerializer.Serialize(L["Cat_OffcanvasEdit"].Value);
    var jsCatDeleteLabel = JsonSerializer.Serialize(L["Cat_OffcanvasDelete"].Value);
    var jsCommonLoading = JsonSerializer.Serialize(L["Common_Loading"].Value);
}

<div class="mb-4">
    <h1 class="visually-hidden">@L["Cat_PageTitle"]</h1>
    <p class="page-subtitle mb-3">@L["Cat_Subtitle"]</p>
    <div class="d-flex flex-wrap gap-2 align-items-center">
        <button type="button" id="btnAddCategory" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> @L["Cat_AddNew"]
        </button>
        <div class="btn-group btn-group-sm" role="group" aria-label="@L["Cat_FilterAria"]">
            <button type="button" class="btn btn-outline-secondary active" data-filter="all">@L["Cat_FilterAll"]</button>
            <button type="button" class="btn btn-outline-secondary" data-filter="Expense">@L["Cat_FilterExpense"]</button>
            <button type="button" class="btn btn-outline-secondary" data-filter="Income">@L["Cat_FilterIncome"]</button>
            <button type="button" class="btn btn-outline-secondary" data-filter="Both">@L["Cat_FilterBoth"]</button>
        </div>
    </div>
</div>

<!-- Offcanvas for category create/edit/delete (like Expense) -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="categoryOffcanvas" aria-labelledby="categoryOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title fw-600" id="categoryOffcanvasLabel">@L["Cat_OffcanvasTitle"]</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="@L["Common_Close"]"></button>
    </div>
    <div class="offcanvas-body px-0">
        <div class="p-3 d-flex align-items-center justify-content-center min-vh-25" id="categoryOffcanvasContent">
            <div class="text-center text-muted"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>@L["Common_Loading"]</div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table id="categoryTable" class="table table-hover mb-0" aria-label="@L["Cat_TableAria"]">
                <caption class="visually-hidden">@L["Cat_TableCaption"]</caption>
                <thead>
                    <tr>
                        <th>@L["Cat_ColName"]</th>
                        <th>@L["Cat_ColUseFor"]</th>
                        <th>@L["Cat_ColDescription"]</th>
                        <th style="width: 220px;">@L["Cat_ColActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Items)
                    {
                        var type = category.Type;
                        var isExpense = type == FinanceApp.Domain.Enums.CategoryType.Expense;
                        var isIncome = type == FinanceApp.Domain.Enums.CategoryType.Income;
                        var isBoth = type == FinanceApp.Domain.Enums.CategoryType.Both;
                        <tr data-category-type="@type">
                            <td>
                                @{ var bg = string.IsNullOrEmpty(category.BadgeColor) ? "#6c757d" : category.BadgeColor; }
                                <span class="category-badge" style="background:@bg; color:#fff;">
                                    @if (!string.IsNullOrEmpty(category.Icon))
                                    {
                                        <i class="bi bi-@category.Icon" style="color:#fff"></i>
                                    }
                                    @category.Name
                                </span>
                            </td>
                            <td>
                                <span class="badge @(isExpense ? "bg-danger" : isIncome ? "bg-success" : "bg-secondary")">@(isExpense ? L["Cat_BadgeExpenseOnly"].Value : isIncome ? L["Cat_BadgeIncomeOnly"].Value : L["Cat_BadgeBoth"].Value)</span>
                            </td>
                            <td>@category.Description</td>
                            <td>
                                <a class="btn btn-sm btn-warning btn-edit" href="@Url.Action("Edit", "Category", new { id = category.Id })" title="@L["Common_Edit"]" aria-label="@L["Cat_EditAria"]">
                                    <i class="bi bi-pencil" aria-hidden="true"></i>
                                </a>
                                <a class="btn btn-sm btn-danger btn-delete" href="@Url.Action("Delete", "Category", new { id = category.Id })" title="@L["Common_Delete"]" aria-label="@L["Cat_DeleteAria"]">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </a>
                                @if (isExpense || isBoth)
                                {
                                    <a asp-controller="Expense" asp-action="ByCategory" asp-route-categoryId="@category.Id" class="btn btn-sm btn-info" title="@L["Cat_ViewExpensesTitle"]" aria-label="@L["Cat_ViewExpensesAria"]">
                                        <i class="bi bi-cash-stack" aria-hidden="true"></i>
                                    </a>
                                }
                                @if (isIncome || isBoth)
                                {
                                    <a asp-controller="Income" asp-action="Index" class="btn btn-sm btn-success" title="@L["Cat_ViewIncomeTitle"]" aria-label="@L["Cat_ViewIncomeAria"]">
                                        <i class="bi bi-arrow-down-circle" aria-hidden="true"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $('#categoryTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                pageLength: 10,
                language: {
                    search: "",
                    searchPlaceholder: @Html.Raw(jsCatDtSearch),
                    info: @Html.Raw(jsCatDtInfo),
                    infoFiltered: @Html.Raw(jsCatDtFiltered),
                    lengthMenu: @Html.Raw(jsCatDtLength),
                    paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                }
            });

            document.getElementById('btnAddCategory')?.addEventListener('click', async function(e) {
                e.preventDefault();
                var content = document.getElementById('categoryOffcanvasContent');
                var label = document.getElementById('categoryOffcanvasLabel');
                var offcanvasEl = document.getElementById('categoryOffcanvas');
                if (label) label.textContent = @Html.Raw(jsCatAddLabel);
                if (content) content.innerHTML = '<div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>' + @Html.Raw(jsCommonLoading) + '</div>';
                if (offcanvasEl) { var o = new bootstrap.Offcanvas(offcanvasEl); o.show(); }
                var url = '@Url.Action("Create", "Category")?partial=true';
                var res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) { var em = @Html.Raw(jsCatErrLoad); if (typeof showToast === 'function') showToast(em); else alert(em); return; }
                var html = await res.text();
                if (content) content.innerHTML = html;
                if (typeof initCategoryForm === 'function') initCategoryForm(content || document);
            });

            document.querySelector('#categoryTable').addEventListener('click', async function(e){
                const editBtn = e.target.closest('.btn-edit');
                if (editBtn) {
                    e.preventDefault();
                    const href = editBtn.getAttribute('href');
                    if (!href) return;
                    var label = document.getElementById('categoryOffcanvasLabel');
                    if (label) label.textContent = @Html.Raw(jsCatEditLabel);
                    const url = href + (href.indexOf('?') === -1 ? '?partial=true' : '&partial=true');
                    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                    if (!res.ok) { var ee = @Html.Raw(jsCatErrEdit); if (typeof showToast === 'function') showToast(ee); else alert(ee); return; }
                    const html = await res.text();
                    document.getElementById('categoryOffcanvasContent').innerHTML = html;
                    const offcanvasEl = document.getElementById('categoryOffcanvas');
                    const bsOff = new bootstrap.Offcanvas(offcanvasEl);
                    bsOff.show();
                    if (typeof initCategoryForm === 'function') initCategoryForm(document.getElementById('categoryOffcanvasContent') || document);
                    return;
                }

                const delBtn = e.target.closest('.btn-delete');
                if (delBtn) {
                    e.preventDefault();
                    const href = delBtn.getAttribute('href');
                    if (!href) return;
                    var label = document.getElementById('categoryOffcanvasLabel');
                    if (label) label.textContent = @Html.Raw(jsCatDeleteLabel);
                    const url = href + (href.indexOf('?') === -1 ? '?partial=true' : '&partial=true');
                    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                    if (!res.ok) { var dm = @Html.Raw(jsCatErrDelete); if (typeof showToast === 'function') showToast(dm); else alert(dm); return; }
                    const html = await res.text();
                    document.getElementById('categoryOffcanvasContent').innerHTML = html;
                    const offcanvasEl = document.getElementById('categoryOffcanvas');
                    const bsOff = new bootstrap.Offcanvas(offcanvasEl);
                    bsOff.show();
                    return;
                }
            });

            document.querySelectorAll('[data-filter]').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var filter = this.getAttribute('data-filter');
                    document.querySelectorAll('[data-filter]').forEach(function(b) { b.classList.remove('active'); });
                    this.classList.add('active');
                    var rows = document.querySelectorAll('#categoryTable tbody tr[data-category-type]');
                    rows.forEach(function(row) {
                        var type = row.getAttribute('data-category-type');
                        var show = filter === 'all' || type === filter;
                        row.style.display = show ? '' : 'none';
                    });
                });
            });
        });
    </script>
}
