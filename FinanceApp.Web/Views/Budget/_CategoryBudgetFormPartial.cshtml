@model FinanceApp.Web.Models.CategoryBudgetViewModel
@{
    var monthName = ViewBag.MonthName as string ?? new DateTime(Model.Year, Model.Month, 1).ToString("MMMM yyyy");
    var categories = ViewBag.AvailableCategories as IEnumerable<FinanceApp.Domain.Entities.Category> ?? Enumerable.Empty<FinanceApp.Domain.Entities.Category>();
}

<form asp-action="SetCategoryBudget" method="post" id="categoryBudgetForm" class="p-3">
    <input type="hidden" asp-for="Month" />
    <input type="hidden" asp-for="Year" />
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">@L["Lbl_Category"]</label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">@L["Bud_SelectCategory"]</option>
            @foreach (var c in categories)
            {
                <option value="@c.Id">@c.Name</option>
            }
        </select>
        @if (!categories.Any())
        {
            <small class="text-muted">@L["Bud_CatAllSet", monthName]</small>
        }
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">@L["Lbl_BudgetAmount"]</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" placeholder="@L["Bud_CatPlaceholder"]" />
        <span asp-validation-for="Amount" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            @foreach (var c in Enum.GetValues(typeof(FinanceApp.Domain.Enums.Currency)))
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">@L["Bud_SaveCatBudget"]</button>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
    </div>
</form>
<partial name="_ValidationScriptsPartial" />
