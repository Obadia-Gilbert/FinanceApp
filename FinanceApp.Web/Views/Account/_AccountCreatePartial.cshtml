@model FinanceApp.Web.Models.AccountCreateViewModel

<form asp-action="Create" asp-controller="Account" method="post" class="p-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Account Name</label>
        <input asp-for="Name" class="form-control" placeholder="e.g. CRDB Savings" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label">Account Type</label>
        <select asp-for="Type" class="form-select">
            @foreach (var type in Enum.GetValues(typeof(FinanceApp.Domain.Enums.AccountType)))
            {
                <option value="@type">@type</option>
            }
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">Currency</label>
        <select asp-for="Currency" class="form-select">
            @foreach (var c in Enum.GetValues(typeof(FinanceApp.Domain.Enums.Currency)))
            {
                <option value="@c">@c</option>
            }
        </select>
        <span asp-validation-for="Currency" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="InitialBalance" class="form-label">Initial Balance</label>
        <input asp-for="InitialBalance" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
        <span asp-validation-for="InitialBalance" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description <span class="text-muted fw-normal">(optional)</span></label>
        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Short note about this account"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>Create Account
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />
