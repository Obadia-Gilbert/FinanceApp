@using System.Text.Json
@model IEnumerable<FinanceApp.Web.Models.AccountViewModel>

@{
    ViewData["Title"] = L["Acc_PageTitle"].Value;
    var jsLoading = JsonSerializer.Serialize(L["Common_Loading"].Value);
    var jsFailedLoad = JsonSerializer.Serialize(L["Acc_FailedLoadForm"].Value);
}

<div class="mb-4">
    <h1 class="visually-hidden">@L["Acc_PageTitle"]</h1>
    <p class="page-subtitle mb-3">@L["Acc_Subtitle"]</p>
    <div class="d-flex gap-2 mb-3">
        <button id="btnAddAccount" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> @L["Acc_Add"]
        </button>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="accountOffcanvas" aria-labelledby="accountOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 id="accountOffcanvasLabel">@L["Acc_OffcanvasTitle"]</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="@L["Common_Close"]"></button>
        </div>
        <div class="offcanvas-body px-0">
            <div class="p-3 d-flex align-items-center justify-content-center min-vh-25" id="accountOffcanvasContent">
                <div class="text-center text-muted"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>@L["Common_Loading"]</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>@L["Acc_EmptyPart1"]<strong>@L["Acc_AddStrong"]</strong>@L["Acc_EmptyPart2"]
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var account in Model.Where(a => a.IsActive))
        {
            var typeIcon = account.Type switch
            {
                FinanceApp.Domain.Enums.AccountType.Savings => "bi-piggy-bank",
                FinanceApp.Domain.Enums.AccountType.Investment => "bi-graph-up-arrow",
                FinanceApp.Domain.Enums.AccountType.CreditCard => "bi-credit-card",
                FinanceApp.Domain.Enums.AccountType.Cash => "bi-cash-stack",
                _ => "bi-bank"
            };
            var balanceClass = account.CurrentBalance >= 0 ? "text-success" : "text-danger";
            <div class="col-sm-6 col-lg-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-2">
                            <span class="fs-3 me-2 text-primary"><i class="bi @typeIcon"></i></span>
                            <div>
                                <h6 class="card-title mb-0">@account.Name</h6>
                                <small class="text-muted">@AccountDisplayHelper.LocalizedAccountType(L, account.Type) · @account.Currency</small>
                            </div>
                        </div>
                        <p class="fs-5 fw-bold @balanceClass mb-1">
                            @account.Currency @account.CurrentBalance.ToString("N2")
                        </p>
                        @if (!string.IsNullOrEmpty(account.Description))
                        {
                            <p class="text-muted small mb-2">@account.Description</p>
                        }
                        <div class="d-flex gap-2 mt-auto">
                            <a href="@Url.Action("Edit", "Account", new { id = account.Id })" class="btn btn-sm btn-outline-secondary btn-edit">
                                <i class="bi bi-pencil"></i> @L["Acc_Edit"]
                            </a>
                            <form method="post" asp-action="Delete" asp-route-id="@account.Id" onsubmit="return confirm(@JsonSerializer.Serialize(L["Acc_DeactivateConfirm", account.Name ?? ""].Value));">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-archive"></i> @L["Acc_Deactivate"]
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.Any(a => !a.IsActive))
    {
        <details class="mb-3">
            <summary class="text-muted small mb-2">@L["Acc_InactiveSummary", Model.Count(a => !a.IsActive)]</summary>
            <div class="row g-3 mt-1">
                @foreach (var account in Model.Where(a => !a.IsActive))
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="card shadow-sm h-100 border-secondary opacity-75">
                            <div class="card-body">
                                <h6 class="card-title text-muted">@account.Name <span class="badge bg-secondary ms-1">@L["Acc_InactiveBadge"]</span></h6>
                                <small class="text-muted">@AccountDisplayHelper.LocalizedAccountType(L, account.Type) · @account.Currency</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </details>
    }
}

@section Scripts {
    <script>
        (function () {
            const offcanvasEl = document.getElementById('accountOffcanvas');
            const content = document.getElementById('accountOffcanvasContent');

            async function loadIntoOffcanvas(url) {
                content.innerHTML = '<div class="text-center text-muted p-4"><span class="spinner-border spinner-border-sm me-2"></span>' + @Html.Raw(jsLoading) + '</div>';
                const bsOff = bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl);
                bsOff.show();
                const res = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) { if (typeof showToast === 'function') showToast(@Html.Raw(jsFailedLoad)); return; }
                content.innerHTML = await res.text();
            }

            document.getElementById('btnAddAccount')?.addEventListener('click', () =>
                loadIntoOffcanvas('@Url.Action("Create", "Account")?partial=true'));

            document.getElementById('accountCardsRow')?.addEventListener('click', async function (e) {
                const editBtn = e.target.closest('.btn-edit');
                if (editBtn) {
                    e.preventDefault();
                    const href = editBtn.getAttribute('href');
                    if (!href) return;
                    await loadIntoOffcanvas(href + (href.includes('?') ? '&' : '?') + 'partial=true');
                }
            });

            offcanvasEl?.addEventListener('submit', async function (e) {
                const form = e.target.closest('form');
                if (!form || !offcanvasEl.contains(form)) return;
                e.preventDefault();
                const data = new FormData(form);
                const res = await fetch(form.action, { method: 'POST', body: data, credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const json = await res.json().catch(() => null);
                if (json?.success) {
                    bootstrap.Offcanvas.getInstance(offcanvasEl)?.hide();
                    location.reload();
                } else {
                    const html = await res.text().catch(() => null);
                    if (html) content.innerHTML = html;
                }
            });
        })();
    </script>
}
