@using FinanceApp.Domain.Entities
@{
    ViewData["Title"] = L["Notif_PageTitle"].Value;
    var notifications = ViewBag.Notifications as IEnumerable<Notification> ?? Enumerable.Empty<Notification>();
    var totalItems = ViewBag.TotalItems as int? ?? 0;
    var pageNumber = ViewBag.PageNumber as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 25;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="visually-hidden">@L["Notif_PageTitle"]</h1>
            <p class="text-muted small mb-0">@L["Notif_Subtitle"]</p>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            @if (!notifications.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-5 text-muted">
                        <i class="bi bi-bell display-4 d-block mb-2"></i>
                        <p class="mb-0">@L["Notif_Empty"]</p>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary btn-sm mt-3">@L["Notif_GoDashboard"]</a>
                    </div>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush shadow-sm rounded overflow-hidden">
                    @foreach (var n in notifications)
                    {
                        var link = !string.IsNullOrEmpty(n.RelatedLink) ? n.RelatedLink : "#";
                        var itemClass = n.IsRead ? "list-group-item" : "list-group-item notification-unread";
                        <a href="@link" class="@itemClass list-group-item-action d-flex gap-2 py-3">
                            <span class="flex-shrink-0 mt-1">
                                @switch (n.Type)
                                {
                                    case FinanceApp.Domain.Enums.NotificationType.BudgetExceeded:
                                    case FinanceApp.Domain.Enums.NotificationType.CategoryBudgetExceeded:
                                        <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                                        break;
                                    case FinanceApp.Domain.Enums.NotificationType.CategoryBudgetWarning:
                                        <i class="bi bi-exclamation-circle text-warning"></i>
                                        break;
                                    default:
                                        <i class="bi bi-info-circle text-primary"></i>
                                        break;
                                }
                            </span>
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-semibold">@n.Title</div>
                                <div class="small text-muted">@n.Message</div>
                                <div class="small text-muted mt-1">@n.CreatedAt.LocalDateTime.ToString("MMM d, yyyy HH:mm")</div>
                            </div>
                        </a>
                    }
                </div>
                @if (totalPages > 1)
                {
                    <nav class="mt-3 d-flex justify-content-between align-items-center">
                        <div class="small text-muted">@L["Notif_PageOf", pageNumber, totalPages, totalItems]</div>
                        <div>
                            @if (pageNumber > 1)
                            {
                                <a asp-action="Index" asp-route-page="@(pageNumber - 1)" asp-route-pageSize="@pageSize" class="btn btn-outline-secondary btn-sm">@L["Notif_Previous"]</a>
                            }
                            @if (pageNumber < totalPages)
                            {
                                <a asp-action="Index" asp-route-page="@(pageNumber + 1)" asp-route-pageSize="@pageSize" class="btn btn-outline-secondary btn-sm ms-1">@L["Notif_Next"]</a>
                            }
                        </div>
                    </nav>
                }
            }
        </div>
    </div>
</div>
