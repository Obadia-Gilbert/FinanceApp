@{
    Layout = "~/Views/Shared/_LayoutLanding.cshtml";
}
@section Head {
    <meta name="keywords" content="@L["Land_MetaKeywords"]" />
}

<section class="landing-hero">
    <div class="container">
        <h1>@L["Land_HeroH1"]</h1>
        <p class="lead">@L["Land_HeroLead"]</p>
        <div class="landing-cta-group">
            <a class="btn btn-primary btn-lg px-4" asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="/Home/Index">@L["Land_GetStartedFree"]</a>
            <a class="btn btn-outline-secondary btn-lg px-4" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Home/Index">@L["Land_SignIn"]</a>
        </div>
        <p class="small text-muted">@L["Land_HeroSubtle"]</p>
    </div>
</section>

<section class="landing-section" id="features">
    <div class="container">
        <h2 class="landing-section-title">@L["Land_FeaturesTitle"]</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="landing-feature-card">
                    <i class="bi bi-wallet2"></i>
                    <h3>@L["Land_Feat1Title"]</h3>
                    <p>@L["Land_Feat1Body"]</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="landing-feature-card">
                    <i class="bi bi-pie-chart"></i>
                    <h3>@L["Land_Feat2Title"]</h3>
                    <p>@L["Land_Feat2Body"]</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="landing-feature-card">
                    <i class="bi bi-graph-up"></i>
                    <h3>@L["Land_Feat3Title"]</h3>
                    <p>@L["Land_Feat3Body"]</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="landing-feature-card">
                    <i class="bi bi-currency-exchange"></i>
                    <h3>@L["Land_Feat4Title"]</h3>
                    <p>@L["Land_Feat4Body"]</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="landing-section" id="how-it-works">
    <div class="container">
        <h2 class="landing-section-title">@L["Land_HowTitle"]</h2>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <ol class="landing-steps">
                    <li>
                        <div>
                            <h4>@L["Land_Step1Title"]</h4>
                            <p>@L["Land_Step1Body"]</p>
                        </div>
                    </li>
                    <li>
                        <div>
                            <h4>@L["Land_Step2Title"]</h4>
                            <p>@L["Land_Step2Body"]</p>
                        </div>
                    </li>
                    <li>
                        <div>
                            <h4>@L["Land_Step3Title"]</h4>
                            <p>@L["Land_Step3Body"]</p>
                        </div>
                    </li>
                    <li>
                        <div>
                            <h4>@L["Land_Step4Title"]</h4>
                            <p>@L["Land_Step4Body"]</p>
                        </div>
                    </li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="landing-section">
    <div class="container">
        <div class="landing-cta-block">
            <h2>@L["Land_CtaH2"]</h2>
            <p class="mb-0">@L["Land_CtaLead"]</p>
            <div class="landing-cta-group mt-3">
                <a class="btn btn-primary btn-lg px-4" asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="/Home/Index">@L["Land_GetStartedFree"]</a>
                <a class="btn btn-outline-secondary btn-lg px-4" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Home/Index">@L["Land_SignIn"]</a>
            </div>
        </div>
    </div>
</section>
