@model FinanceApp.Web.Models.ProfileEditViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="mb-4">
    <h1 class="visually-hidden">Edit Profile</h1>
    <p class="page-subtitle mb-0">Update your name, phone, country, and profile photo.</p>
</div>

@if (TempData["ProfileUpdated"] as bool? == true)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>Profile updated successfully.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-area="" asp-controller="Profile" asp-action="Edit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row">
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <label class="form-label fw-600">Current Photo</label>
                    <div class="mb-2">
                        @if (!string.IsNullOrEmpty(Model.CurrentProfileImagePath))
                        {
                            <img src="@Model.CurrentProfileImagePath" alt="Profile" class="rounded-circle" style="width: 120px; height: 120px; object-fit: cover;" />
                        }
                        else
                        {
                            var initial = string.IsNullOrWhiteSpace(Model.FirstName) && string.IsNullOrWhiteSpace(Model.LastName)
                                ? (Model.Email?.Length > 0 ? Model.Email[0].ToString().ToUpperInvariant() : "?")
                                : (Model.FirstName?.Trim().Length > 0 ? Model.FirstName.Trim()[0].ToString().ToUpperInvariant() : (Model.LastName?.Trim().Length > 0 ? Model.LastName.Trim()[0].ToString().ToUpperInvariant() : "?"));
                            <span class="rounded-circle d-inline-flex align-items-center justify-content-center bg-primary text-white" style="width: 120px; height: 120px; font-size: 3rem;">@initial</span>
                        }
                    </div>
                    <div>
                        <label asp-for="ProfileImage" class="form-label small">Change photo</label>
                        <input asp-for="ProfileImage" type="file" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.gif,.webp" />
                        <small class="text-muted">JPG, PNG, GIF or WebP. Leave empty to keep current.</small>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="PreferredLanguage" class="form-label fw-600">@L["Lang_Language"]</label>
                        <select asp-for="PreferredLanguage" class="form-select">
                            <option value="en">@L["Lang_English"]</option>
                            <option value="sw">@L["Lang_Swahili"]</option>
                            <option value="es">@L["Lang_Spanish"]</option>
                        </select>
                        <span asp-validation-for="PreferredLanguage" class="invalid-feedback d-block small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-600">Email</label>
                        <input asp-for="Email" class="form-control" readonly disabled />
                        <small class="text-muted">Email cannot be changed here.</small>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label fw-600">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="First name" />
                        <span asp-validation-for="FirstName" class="invalid-feedback d-block small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label fw-600">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="Last name" />
                        <span asp-validation-for="LastName" class="invalid-feedback d-block small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CountryCode" class="form-label fw-600">Country</label>
                        <select asp-for="CountryCode" asp-items="ViewBag.Countries" class="form-select" id="profileCountryCode">
                        </select>
                        <small class="text-muted">Select country first — dialing prefix is inserted, then you type the remaining digits.</small>
                        <span asp-validation-for="CountryCode" class="invalid-feedback d-block small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label fw-600">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" type="tel" id="profilePhoneNumber" placeholder="e.g. +255 712 345 678" autocomplete="tel" />
                        <small class="text-muted">Prefix is derived from country. You can edit only the part after the prefix.</small>
                        <span asp-validation-for="PhoneNumber" class="invalid-feedback d-block small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i> Save changes
                        </button>
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/libphonenumber-js@1.10.51/bundle.min.js" crossorigin="anonymous"></script>
    <script>
    (function() {
        var countrySelect = document.getElementById('profileCountryCode');
        var phoneInput = document.getElementById('profilePhoneNumber');
        if (!countrySelect || !phoneInput) return;
        var lib = window.libphonenumber;
        // Important: do NOT hard-return if the CDN failed to expose libphonenumber-js.
        // We still want to insert "+<dialingCode>" using our fallback map.

        function getCountry() {
            var code = (countrySelect.value || '').trim().toUpperCase();
            return code || null;
        }

        function getCallingCode(country) {
            if (!country) return null;
            // Fallback for our supported profile country list.
            // This keeps prefix insertion working even if the CDN bundle
            // doesn't expose libphonenumber-js in the browser runtime.
            var FALLBACK_CALLING_CODES = {
                TZ: '255',
                UG: '256',
                KE: '254',
                RW: '250',
                US: '1',
                GB: '44',
                CA: '1',
                AU: '61',
                DE: '49',
                FR: '33',
                IN: '91',
                ZA: '27',
                NG: '234',
                GH: '233',
                ET: '251',
                CN: '86',
                JP: '81',
                BR: '55',
                MX: '52',
                NL: '31',
                CH: '41',
                AE: '971',
                SA: '966',
                EG: '20',
                ZW: '263',
                ZM: '260',
                MW: '265',
                MZ: '258',
                BW: '267',
                NA: '264',
            };

            if (!lib) return FALLBACK_CALLING_CODES[country] || null;

            if (typeof lib.getCountryCallingCode === 'function') {
                try { return lib.getCountryCallingCode(country) || null; } catch (e) { return null; }
            }

            // Fallback: derive calling code by parsing a dummy value in the selected region.
            // This keeps behavior working even if the CDN global doesn't expose getCountryCallingCode.
            try {
                var formatter = new lib.AsYouType(country);
                formatter.input('0');
                var num = formatter.getNumber();
                var derived = num && num.countryCallingCode ? String(num.countryCallingCode) : null;
                return derived || FALLBACK_CALLING_CODES[country] || null;
            } catch (e2) {
                return FALLBACK_CALLING_CODES[country] || null;
            }
        }

        function normalizeDigits(str) {
            return (str || '').replace(/\D/g, '');
        }

        function getNationalDigits(country, rawValue) {
            var callingCode = getCallingCode(country);
            var normalized = (rawValue || '').replace(/\s+/g, '').trim();
            var digits = normalizeDigits(normalized);
            if (!callingCode) return digits;

            // If user already has an international prefix, strip it to get national digits.
            var plusPrefix = '+' + callingCode;
            if (normalized.startsWith(plusPrefix)) {
                var after = normalized.slice(plusPrefix.length);
                return normalizeDigits(after);
            }
            if (normalized.startsWith(callingCode)) {
                var afterNoPlus = normalized.slice(callingCode.length);
                return normalizeDigits(afterNoPlus);
            }
            // Otherwise assume it's already the national number digits.
            return digits;
        }

        function setCaretAfterCallingCode(country) {
            // Lock prefix as whatever "+<digits><optional spaces>" is currently in the input.
            // (Avoids relying on a specific callingCode extraction API.)
            var value = phoneInput.value || '';
            var m = value.match(/^\+\d+\s*/);
            if (m && typeof phoneInput.setSelectionRange === 'function') {
                var pos = m[0].length;
                phoneInput.setSelectionRange(pos, pos);
            }
        }

        function formatPhone(insertPrefixIfEmpty) {
            var country = getCountry();
            var callingCode = getCallingCode(country);

            if (!country || !callingCode) {
                // No country selected: keep existing behavior as a best-effort parse/format.
                var value = (phoneInput.value || '').trim().replace(/\s+/g, '');
                if (!value) return;
                try {
                    var parsed = lib.parsePhoneNumber(value);
                    if (parsed) phoneInput.value = parsed.formatInternational();
                } catch (e) {}
                return;
            }

            var rawValue = phoneInput.value || '';
            var nationalDigits = getNationalDigits(country, rawValue);

            var prefix = '+' + callingCode + ' ';
            if (!nationalDigits) {
                if (insertPrefixIfEmpty) {
                    phoneInput.value = prefix;
                    setCaretAfterCallingCode(country);
                }
                return;
            }

            try {
                if (!lib || typeof lib.AsYouType !== 'function') {
                    phoneInput.value = prefix + nationalDigits;
                    setCaretAfterCallingCode(country);
                    return;
                }
                var formatter = new lib.AsYouType(country);
                var formattedSoFar = formatter.input(nationalDigits);
                var num = formatter.getNumber();
                phoneInput.value = num ? num.formatInternational() : (formattedSoFar || (prefix + nationalDigits));
                setCaretAfterCallingCode(country);
            } catch (e) {
                // Fallback: still show prefix + digits so the UX remains consistent.
                phoneInput.value = prefix + nationalDigits;
                setCaretAfterCallingCode(country);
            }
        }

        // Prevent the user from deleting/changing the prefix part.
        // We compute the *actual* end index of "+<callingCode><optional spaces>" in the current value.
        function getPrefixLengthForCurrentCountry() {
            var value = phoneInput.value || '';
            var m = value.match(/^\+\d+\s*/);
            return m ? m[0].length : 0;
        }

        countrySelect.addEventListener('change', function() {
            // On country change: always insert prefix and keep cursor after it.
            formatPhone(true);
        });

        // Keep formatting on blur so partially typed input becomes nicely formatted.
        phoneInput.addEventListener('blur', function() {
            formatPhone(false);
        });

        // Hard UX guard: disallow deleting before prefix and keep caret after prefix.
        phoneInput.addEventListener('focus', function() {
            var prefixLen = getPrefixLengthForCurrentCountry();
            if (!prefixLen) return;
            var pos = phoneInput.selectionStart || 0;
            if (pos < prefixLen) phoneInput.setSelectionRange(prefixLen, prefixLen);
        });
        phoneInput.addEventListener('click', function() {
            var prefixLen = getPrefixLengthForCurrentCountry();
            if (!prefixLen) return;
            var pos = phoneInput.selectionStart || 0;
            if (pos < prefixLen) phoneInput.setSelectionRange(prefixLen, prefixLen);
        });
        phoneInput.addEventListener('keydown', function(e) {
            var prefixLen = getPrefixLengthForCurrentCountry();
            if (!prefixLen) return;

            var start = phoneInput.selectionStart || 0;
            var end = phoneInput.selectionEnd || start;

            // Block Backspace/Delete actions that would touch prefix.
            if ((e.key === 'Backspace' || e.key === 'Delete') && start <= prefixLen) {
                e.preventDefault();
                return;
            }

            // If user tries to select text that includes prefix, force caret after prefix.
            if (start < prefixLen || end < prefixLen) {
                // Let normal typing happen after the caret.
                phoneInput.setSelectionRange(prefixLen, prefixLen);
            }
        });

        // Initial load: if we already have phone + a selected country, ensure the prefix UX is applied.
        if (getCountry()) {
            formatPhone(true);
        }
    })();
    </script>
}
