@model FinanceApp.Web.Models.IncomeEditViewModel
@using FinanceApp.Domain.Enums
@using FinanceApp.Web.Models
@{
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account>;
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category>;
    var currencies = ViewBag.Currencies as IEnumerable<FinanceApp.Domain.Enums.Currency>;
    var supportingDocs = ViewBag.SupportingDocs as IEnumerable<FinanceApp.Domain.Entities.SupportingDocument> ?? Enumerable.Empty<FinanceApp.Domain.Entities.SupportingDocument>();
}

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="p-3">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">Account <span class="text-muted">(optional)</span></label>
        <select asp-for="AccountId" class="form-select">
            <option value="">— None (tracking only) —</option>
            @if (accounts != null)
            {
                @foreach (var acc in accounts)
                {
                    <option value="@acc.Id">@acc.Name (@acc.Currency)</option>
                }
            }
        </select>
        <span asp-validation-for="AccountId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Income category</label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">-- Select Category --</option>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Amount</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Currency" class="form-label">Currency</label>
        <select asp-for="Currency" class="form-select">
            @if (currencies != null)
            {
                @foreach (var c in currencies)
                {
                    <option value="@c">@c</option>
                }
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="IncomeDate" class="form-label">Date</label>
        <input asp-for="IncomeDate" type="date" class="form-control" />
        <span asp-validation-for="IncomeDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <input asp-for="Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Source" class="form-label">Source</label>
        <input asp-for="Source" class="form-control" />
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save</button>
    </div>
</form>

<div class="border-top px-3 pt-2 pb-3">
    @await Html.PartialAsync("_SupportingDocuments", new SupportingDocumentsViewModel
    {
        EntityType = DocumentEntityType.Income,
        EntityId   = Model.Id,
        Documents  = supportingDocs,
        ReturnUrl  = Url.Action("Index", "Income") ?? "/Income",
        ReloadUrl  = Url.Action("Edit", "Income", new { id = Model.Id })
    })
</div>
<partial name="_ValidationScriptsPartial" />
