@model IEnumerable<FinanceApp.Web.Models.IncomeListViewModel>
@using System.Text.Json
@{
    ViewData["Title"] = L["Inc_PageTitle"].Value;
    int pageNumber = ViewBag.PageNumber ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    var jsIncDel = JsonSerializer.Serialize(L["Inc_DeleteConfirm"].Value);
    var jsCommonLoading = JsonSerializer.Serialize(L["Common_Loading"].Value);
}

<div class="mb-4">
    <h1 class="visually-hidden">@L["Inc_PageTitle"]</h1>
    <p class="page-subtitle mb-3">@L["Inc_Subtitle"]</p>
    <div class="d-flex gap-2 mb-3">
        <button id="btnAddIncome" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> @L["Inc_Add"]
        </button>
    </div>

    <div class="offcanvas offcanvas-end" tabindex="-1" id="incomeOffcanvas" aria-labelledby="incomeOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 id="incomeOffcanvasLabel">@L["Inc_OffcanvasTitle"]</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="@L["Common_Close"]"></button>
        </div>
        <div class="offcanvas-body px-0">
            <div class="p-3 d-flex align-items-center justify-content-center min-vh-25" id="incomeOffcanvasContent">
                <div class="text-center text-muted"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>@L["Common_Loading"]</div>
            </div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>@L["Inc_EmptyPart1"]<strong>@L["Inc_AddStrong"]</strong>@L["Inc_EmptyPart2"]
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="incomeTable" class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@L["Table_Date"]</th>
                            <th>@L["Tx_ColAccount"]</th>
                            <th>@L["Lbl_Category"]</th>
                            <th class="text-end">@L["Table_Amount"]</th>
                            <th>@L["Inc_ColDescSource"]</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@item.IncomeDate.ToString("yyyy-MM-dd")</td>
                                <td>@(string.IsNullOrEmpty(item.AccountName) ? "—" : item.AccountName)</td>
                                <td>@item.CategoryName</td>
                                <td class="text-end text-success text-nowrap">
                                    <strong>+ @item.Currency @item.Amount.ToString("N2")</strong>
                                </td>
                                <td class="text-truncate" style="max-width:180px;" title="@(item.Description ?? item.Source ?? "—")">@(item.Description ?? item.Source ?? "—")</td>
                                <td class="text-nowrap">
                                    <a href="@Url.Action("Edit", "Income", new { id = item.Id })" class="btn btn-sm btn-outline-secondary btn-edit me-1" title="@L["Common_Edit"]" aria-label="@L["Common_Edit"]">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" asp-action="Delete" asp-controller="Income" asp-route-id="@item.Id" style="display:inline" onsubmit="return confirm(@Html.Raw(jsIncDel));">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="@L["Common_Delete"]" aria-label="@L["Common_Delete"]">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3" aria-label="@L["Inc_PaginationAria"]">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber - 1)">@L["Tx_Prev"]</a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == pageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@p">@p</a>
                    </li>
                }
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber + 1)">@L["Tx_Next"]</a>
                </li>
            </ul>
        </nav>
    }
}

@section Scripts {
    <script>
        (function () {
            const offcanvasEl = document.getElementById('incomeOffcanvas');
            const content = document.getElementById('incomeOffcanvasContent');

            async function loadIntoOffcanvas(url) {
                content.innerHTML = '<div class="text-center text-muted p-4"><span class="spinner-border spinner-border-sm me-2"></span>' + @Html.Raw(jsCommonLoading) + '</div>';
                bootstrap.Offcanvas.getOrCreateInstance(offcanvasEl).show();
                const res = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!res.ok) return;
                content.innerHTML = await res.text();
            }

            document.getElementById('btnAddIncome')?.addEventListener('click', () =>
                loadIntoOffcanvas('@Url.Action("Create", "Income")?partial=true'));

            document.getElementById('incomeTable')?.addEventListener('click', async function (e) {
                const editBtn = e.target.closest('.btn-edit');
                if (editBtn) {
                    e.preventDefault();
                    const href = editBtn.getAttribute('href');
                    if (href) await loadIntoOffcanvas(href + (href.includes('?') ? '&' : '?') + 'partial=true');
                }
            });

            offcanvasEl?.addEventListener('submit', async function (e) {
                const form = e.target.closest('form');
                if (!form || !offcanvasEl.contains(form)) return;
                e.preventDefault();
                const data = new FormData(form);
                data.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
                const res = await fetch(form.action, { method: 'POST', body: data, credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                const json = await res.json().catch(() => null);
                if (json?.success) {
                    bootstrap.Offcanvas.getInstance(offcanvasEl)?.hide();
                    location.reload();
                } else {
                    const html = await res.text().catch(() => null);
                    if (html) content.innerHTML = html;
                }
            });
        })();
    </script>
}
