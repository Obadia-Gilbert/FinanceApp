@model FinanceApp.Web.Models.IncomeCreateViewModel
@{
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account>;
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category>;
    var currencies = ViewBag.Currencies as IEnumerable<FinanceApp.Domain.Enums.Currency>;
}

<form asp-action="Create" method="post" enctype="multipart/form-data" class="p-3">
    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">@L["Lbl_Account"] <span class="text-muted">@L["Inc_AccountOptional"]</span></label>
        <select asp-for="AccountId" class="form-select">
            <option value="">@L["Exp_AccountNone"]</option>
            @if (accounts != null)
            {
                @foreach (var acc in accounts)
                {
                    <option value="@acc.Id">@acc.Name (@acc.Currency)</option>
                }
            }
        </select>
        <small class="text-muted">@L["Inc_AccountHelp"]</small>
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">@L["Inc_IncomeCategory"]</label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">@L["Exp_SelectCategory"]</option>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Amount" class="form-label">@L["Table_Amount"]</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            @if (currencies != null)
            {
                @foreach (var c in currencies)
                {
                    <option value="@c">@c</option>
                }
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="IncomeDate" class="form-label">@L["Lbl_Date"]</label>
        <input asp-for="IncomeDate" type="date" class="form-control" />
        <span asp-validation-for="IncomeDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">@L["Lbl_Description"] <span class="text-muted">@L["Exp_ReceiptOptional"]</span></label>
        <input asp-for="Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Source" class="form-label">@L["Lbl_Source"] <span class="text-muted">@L["Inc_SourceHint"]</span></label>
        <input asp-for="Source" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupportingFile" class="form-label">@L["Inc_SupportingDoc"] <span class="text-muted">@L["Exp_ReceiptOptional"]</span></label>
        <input asp-for="SupportingFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.xls,.xlsx" />
        <small class="text-muted">@L["Inc_FileTypes"]</small>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>@L["Inc_AddIncomeBtn"]</button>
    </div>
</form>
<partial name="_ValidationScriptsPartial" />
