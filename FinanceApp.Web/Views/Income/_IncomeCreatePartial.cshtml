@model FinanceApp.Web.Models.IncomeCreateViewModel
@{
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account>;
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category>;
    var currencies = ViewBag.Currencies as IEnumerable<FinanceApp.Domain.Enums.Currency>;
}

<form asp-action="Create" method="post" enctype="multipart/form-data" class="p-3">
    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">Account <span class="text-muted">(optional — for balance tracking)</span></label>
        <select asp-for="AccountId" class="form-select">
            <option value="">— None (tracking only) —</option>
            @if (accounts != null)
            {
                @foreach (var acc in accounts)
                {
                    <option value="@acc.Id">@acc.Name (@acc.Currency)</option>
                }
            }
        </select>
        <small class="text-muted">Leave as "None" if you don't use accounts; your income will still be listed and included in reports.</small>
    </div>
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Income category</label>
        <select asp-for="CategoryId" class="form-select" required>
            <option value="">-- Select Category --</option>
            @if (categories != null)
            {
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Amount</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Currency" class="form-label">Currency</label>
        <select asp-for="Currency" class="form-select">
            @if (currencies != null)
            {
                @foreach (var c in currencies)
                {
                    <option value="@c">@c</option>
                }
            }
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="IncomeDate" class="form-label">Date</label>
        <input asp-for="IncomeDate" type="date" class="form-control" />
        <span asp-validation-for="IncomeDate" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description <span class="text-muted">(optional)</span></label>
        <input asp-for="Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Source" class="form-label">Source <span class="text-muted">(e.g. employer, client)</span></label>
        <input asp-for="Source" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="SupportingFile" class="form-label">Supporting document <span class="text-muted">(optional)</span></label>
        <input asp-for="SupportingFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.doc,.docx,.xls,.xlsx" />
        <small class="text-muted">JPG, PNG, PDF, Word, Excel. Max 10 MB.</small>
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Add Income</button>
    </div>
</form>
<partial name="_ValidationScriptsPartial" />
