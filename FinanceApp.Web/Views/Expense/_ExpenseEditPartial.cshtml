@model FinanceApp.Web.Models.ExpenseEditViewModel
@using FinanceApp.Domain.Enums
@using FinanceApp.Web.Models

@{
    var categories    = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category> ?? Enumerable.Empty<FinanceApp.Domain.Entities.Category>();
    var supportingDocs = ViewBag.SupportingDocs as IEnumerable<FinanceApp.Domain.Entities.SupportingDocument>
                       ?? Enumerable.Empty<FinanceApp.Domain.Entities.SupportingDocument>();
}

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="p-3">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Description" class="form-label">@L["Lbl_Description"]</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">@L["Table_Amount"]</label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            @foreach (var currency in Enum.GetValues(typeof(Currency)))
            {
                <option value="@currency">@currency</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="ExpenseDate" class="form-label">@L["Lbl_ExpenseDate"]</label>
        <input asp-for="ExpenseDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">@L["Lbl_Category"]</label>
        <select asp-for="CategoryId" class="form-select">
            @foreach (var cat in categories)
            {
                <option value="@cat.Id" selected="@(cat.Id == Model.CategoryId)">@cat.Name</option>
            }
        </select>
    </div>

    @* Legacy receipt — show read-only view/preview links if one exists *@
    @if (!string.IsNullOrEmpty(Model.ReceiptPath))
    {
        <div class="mb-3">
            <label class="form-label small text-muted">@L["Exp_LegacyReceipt"]</label>
            <div class="d-flex align-items-center gap-2">
                <a href="@Url.Action("Receipt", "Expense", new { id = Model.Id })"
                   target="_blank"
                   class="btn btn-sm btn-outline-secondary"
                   title="@L["Exp_ViewNewTab"]">
                    <i class="bi bi-eye me-1"></i>@L["Exp_View"]
                </a>
                <button type="button"
                        class="btn btn-sm btn-outline-secondary btn-preview-receipt"
                        data-expense-id="@Model.Id"
                        title="@L["Exp_PreviewInModal"]">
                    <i class="bi bi-zoom-in me-1"></i>@L["Exp_Preview"]
                </button>
            </div>
        </div>
        <input type="hidden" asp-for="ReceiptPath" />
    }

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>@L["Common_SaveChanges"]
        </button>
    </div>
</form>

@* Supporting Documents widget — OUTSIDE the main form (contains its own forms) *@
<div class="border-top px-3 pt-2 pb-3">
    @await Html.PartialAsync("_SupportingDocuments", new SupportingDocumentsViewModel
    {
        EntityType = DocumentEntityType.Expense,
        EntityId   = Model.Id,
        Documents  = supportingDocs,
        ReturnUrl  = Url.Action("Index", "Expense") ?? "/Expense",
        ReloadUrl  = Url.Action("Edit",  "Expense", new { id = Model.Id })
    })
</div>

<partial name="_ValidationScriptsPartial" />

<script>
    (function () {
        var form = document.querySelector('#expenseOffcanvasContent form');
        if (!form) return;

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var formData = new FormData(form);
            var action = form.getAttribute('action') || window.location.href;
            var res = await fetch(action, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            });

            var contentType = res.headers.get('content-type') || '';
            if (contentType.includes('application/json')) {
                var json = await res.json();
                if (json.success) {
                    var offcanvasEl = document.getElementById('expenseOffcanvas');
                    var bs = bootstrap.Offcanvas.getInstance(offcanvasEl) || new bootstrap.Offcanvas(offcanvasEl);
                    bs.hide();
                    window.location.reload();
                }
                return;
            }

            var html = await res.text();
            var content = document.getElementById('expenseOffcanvasContent');
            content.innerHTML = html;
            if (window.jQuery && jQuery.validator && jQuery.validator.unobtrusive) {
                jQuery.validator.unobtrusive.parse(content);
            }
        });
    })();
</script>
