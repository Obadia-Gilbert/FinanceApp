@model FinanceApp.Web.Models.ExpenseCreateViewModel

@{
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category>;
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account>;
}

<form asp-action="Create" method="post" enctype="multipart/form-data" class="p-3">
    <div class="mb-3">
        <label asp-for="Description" class="form-label">@L["Lbl_Description"]</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">@L["Table_Amount"]</label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            <option value="">@L["Exp_SelectCurrency"]</option>
            @foreach (var currency in Enum.GetValues(typeof(FinanceApp.Domain.Enums.Currency)))
            {
                <option value="@currency">@currency</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="ExpenseDate" class="form-label">@L["Lbl_ExpenseDate"]</label>
        <input asp-for="ExpenseDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="ExpenseDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">@L["Exp_LabelExpenseCategory"]</label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">@L["Exp_SelectCategory"]</option>
            @foreach (var cat in categories ?? Enumerable.Empty<FinanceApp.Domain.Entities.Category>())
            {
                <option value="@cat.Id">@cat.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">@L["Lbl_Account"] <span class="text-muted">@L["Exp_AccountOptional"]</span></label>
        <select asp-for="AccountId" class="form-select">
            <option value="">@L["Exp_AccountNone"]</option>
            @if (accounts != null)
            {
                @foreach (var acc in accounts)
                {
                    <option value="@acc.Id">@acc.Name (@acc.Currency)</option>
                }
            }
        </select>
        <small class="text-muted">@L["Exp_AccountHelp"]</small>
    </div>

    <div class="mb-3">
        <label asp-for="ReceiptFile" class="form-label">@L["Exp_ReceiptLabel"] <span class="text-muted fw-normal">@L["Exp_ReceiptOptional"]</span></label>
        <input asp-for="ReceiptFile" type="file" class="form-control receipt-file-input" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf" />
        <small class="text-muted">@L["Exp_ReceiptTypes"]</small>
        <div class="receipt-preview mt-2 d-none">
            <img src="" alt="Preview" class="receipt-preview-img rounded border" style="max-height: 120px; max-width: 100%; object-fit: contain;" />
            <p class="receipt-preview-pdf small text-muted mt-1 d-none">@L["Exp_PdfWillUpload"]</p>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
        <button type="submit" class="btn btn-primary" id="expenseCreateSubmit">
            <span class="btn-text"><i class="bi bi-check-lg me-1"></i>@L["Exp_CreateExpense"]</span>
            <span class="btn-loading d-none"><span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>@L["Common_Saving"]</span>
        </button>
    </div>
</form>
<script>
    (function() {
        var form = document.querySelector('#expenseOffcanvasContent form');
        if (form) {
            form.addEventListener('submit', function() {
                var btn = document.getElementById('expenseCreateSubmit');
                if (btn) { btn.querySelector('.btn-text')?.classList.add('d-none'); btn.querySelector('.btn-loading')?.classList.remove('d-none'); btn.disabled = true; }
            });
            var fileInput = form.querySelector('.receipt-file-input');
            var preview = form.querySelector('.receipt-preview');
            var previewImg = form.querySelector('.receipt-preview-img');
            var previewPdf = form.querySelector('.receipt-preview-pdf');
            if (fileInput && preview) {
                fileInput.addEventListener('change', function() {
                    var file = this.files?.[0];
                    preview.classList.add('d-none');
                    if (previewImg) previewImg.src = '';
                    if (previewPdf) previewPdf.classList.add('d-none');
                    if (!file) return;
                    var ext = (file.name.split('.').pop() || '').toLowerCase();
                    if (['jpg','jpeg','png','gif','webp'].indexOf(ext) !== -1) {
                        var r = new FileReader();
                        r.onload = function() {
                            previewImg.src = r.result;
                            previewImg.classList.remove('d-none');
                            if (previewPdf) previewPdf.classList.add('d-none');
                            preview.classList.remove('d-none');
                        };
                        r.readAsDataURL(file);
                    } else if (ext === 'pdf') {
                        if (previewImg) previewImg.classList.add('d-none');
                        if (previewPdf) previewPdf.classList.remove('d-none');
                        preview.classList.remove('d-none');
                    }
                });
            }
        }
    })();
</script>

<partial name="_ValidationScriptsPartial" />
