@model FinanceApp.Application.Common.PagedResult<FinanceApp.Domain.Entities.Expense>
@using System.Text.Json
@{
    ViewData["Title"] = L["Exp_PageTitle"].Value;
    var jsExpErrLoad = JsonSerializer.Serialize(L["Exp_ErrLoadForm"].Value);
    var jsExpErrEdit = JsonSerializer.Serialize(L["Exp_ErrLoadEdit"].Value);
    var jsExpErrDelete = JsonSerializer.Serialize(L["Exp_ErrLoadDelete"].Value);
    var jsExpErrReceipt = JsonSerializer.Serialize(L["Exp_ErrLoadReceipt"].Value);
    var jsDtSearch = JsonSerializer.Serialize(L["Exp_DTSearchPlaceholder"].Value);
    var jsDtInfo = JsonSerializer.Serialize(L["Exp_DTInfo"].Value);
    var jsDtFiltered = JsonSerializer.Serialize(L["Exp_DTInfoFiltered"].Value);
    var jsDtLength = JsonSerializer.Serialize(L["Exp_DTLengthMenu"].Value);
    var jsCommonLoading = JsonSerializer.Serialize(L["Common_Loading"].Value);
}

<div class="mb-4">
    <h1 class="visually-hidden">@L["Exp_PageTitle"]</h1>
    <p class="page-subtitle mb-3">@L["Exp_Subtitle"]</p>
    <div class="d-flex gap-2 mb-3">
        <button id="btnAddExpense" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> @L["Exp_AddNew"]
        </button>
        <a class="btn btn-success" asp-action="DownloadExcel">
            <i class="bi bi-download"></i> @L["Exp_DownloadExcel"]
        </a>
    </div>

    <!-- Offcanvas container for create/edit forms -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="expenseOffcanvas" aria-labelledby="expenseOffcanvasLabel">
        <div class="offcanvas-header">
            <h5 id="expenseOffcanvasLabel">@L["Exp_OffcanvasTitle"]</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="@L["Common_Close"]"></button>
        </div>
        <div class="offcanvas-body px-0">
            <div class="p-3 d-flex align-items-center justify-content-center min-vh-25" id="expenseOffcanvasContent">
                <div class="text-center text-muted"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>@L["Common_Loading"]</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0 px-1">
        <div class="table-responsive">
            <table id="expenseTable" class="table table-hover table-sm mb-0" aria-label="@L["Exp_TableAria"]">
                <caption class="visually-hidden">@L["Exp_TableCaption"]</caption>
                <thead>
                    <tr>
                        <th>@L["Lbl_Description"]</th>
                        <th>@L["Table_Amount"]</th>
                        <th>@L["Exp_ColCurrency"]</th>
                        <th>@L["Lbl_Category"]</th>
                        <th>@L["Table_Date"]</th>
                        <th title="@L["Exp_ColAttachments"]"><i class="bi bi-paperclip"></i></th>
                        <th class="text-center">@L["Table_Actions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var expense in Model.Items)
                    {
                        <tr>
                            <td>@expense.Description</td>
                            <td>@expense.Amount</td>
                            <td>@expense.Currency</td>
                            <td>@expense.Category.Name</td>
                            <td>@expense.ExpenseDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(expense.ReceiptPath))
                                {
                                    <a href="@Url.Action("Receipt", "Expense", new { id = expense.Id })" target="_blank" class="btn btn-sm btn-outline-primary btn-receipt-view" data-expense-id="@expense.Id" title="@L["Exp_ReceiptViewTitle"]">
                                        <i class="bi bi-receipt"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-secondary btn-receipt-preview ms-1" data-expense-id="@expense.Id" title="@L["Exp_ReceiptPreviewTitle"]">
                                        <i class="bi bi-zoom-in"></i>
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <a class="btn btn-sm btn-warning btn-edit" href="@Url.Action("Edit", "Expense", new { id = expense.Id })" title="@L["Common_Edit"]" aria-label="@L["Exp_EditAria"]">
                                    <i class="bi bi-pencil" aria-hidden="true"></i>
                                </a>
                                <a class="btn btn-sm btn-danger btn-delete" href="@Url.Action("Delete", "Expense", new { id = expense.Id })" title="@L["Common_Delete"]" aria-label="@L["Exp_DeleteAria"]">
                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Receipt preview modal -->
<div class="modal fade" id="receiptPreviewModal" tabindex="-1" aria-labelledby="receiptPreviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="receiptPreviewModalLabel">@L["Exp_ReceiptModalTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="@L["Common_Close"]"></button>
            </div>
            <div class="modal-body p-0 text-center bg-dark">
                <div id="receiptPreviewContent" style="min-height: 400px;">
                    <div class="d-flex align-items-center justify-content-center py-5">
                        <div class="spinner-border text-light" role="status"><span class="visually-hidden">@L["Common_Loading"]</span></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a id="receiptPreviewDownload" href="#" target="_blank" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-download me-1"></i>@L["Exp_OpenNewTab"]
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@L["Common_Close"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function(){
            $('#expenseTable').DataTable({
                paging: true,
                searching: true,
                ordering: true,
                pageLength: 10,
                language: {
                    search: "",
                    searchPlaceholder: @Html.Raw(jsDtSearch),
                    info: @Html.Raw(jsDtInfo),
                    infoFiltered: @Html.Raw(jsDtFiltered),
                    lengthMenu: @Html.Raw(jsDtLength),
                    paginate: { first: "«", last: "»", next: "›", previous: "‹" }
                }
            });
        });
    </script>
    <script>
        (function(){
            const btn = document.getElementById('btnAddExpense');
            if (!btn) return;

            btn.addEventListener('click', async function(e){
                e.preventDefault();
                const content = document.getElementById('expenseOffcanvasContent');
                const offcanvasEl = document.getElementById('expenseOffcanvas');
                const loadingHtml = '<div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>' + @Html.Raw(jsCommonLoading) + '</div>';
                content.innerHTML = loadingHtml;
                if (offcanvasEl) { var o = new bootstrap.Offcanvas(offcanvasEl); o.show(); }
                const url = '@Url.Action("Create","Expense")?partial=true';
                const res = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                if (!res.ok) {
                    var msg = @Html.Raw(jsExpErrLoad) + ' (' + res.status + ')';
                    if (typeof showToast === 'function') showToast(msg); else alert(msg);
                    return;
                }
                const html = await res.text();
                content.innerHTML = html;
            });

            // Delegate table actions (edit & delete) to load partials into the same offcanvas
            document.querySelector('#expenseTable').addEventListener('click', async function(e){
                const editBtn = e.target.closest('.btn-edit');
                if (editBtn) {
                    e.preventDefault();
                    const href = editBtn.getAttribute('href');
                    if (!href) return;
                    const url = href + (href.indexOf('?') === -1 ? '?partial=true' : '&partial=true');
                    const res = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                    if (!res.ok) { var em = @Html.Raw(jsExpErrEdit); if (typeof showToast === 'function') showToast(em); else alert(em); return; }
                    const html = await res.text();
                    const content = document.getElementById('expenseOffcanvasContent');
                    content.innerHTML = html;
                    const offcanvasEl = document.getElementById('expenseOffcanvas');
                    const bsOff = new bootstrap.Offcanvas(offcanvasEl);
                    bsOff.show();
                    return;
                }

                const delBtn = e.target.closest('.btn-delete');
                if (delBtn) {
                    e.preventDefault();
                    const href = delBtn.getAttribute('href');
                    if (!href) return;
                    const url = href + (href.indexOf('?') === -1 ? '?partial=true' : '&partial=true');
                    const res = await fetch(url, { credentials: 'include', headers: { 'X-Requested-With': 'XMLHttpRequest' }});
                    if (!res.ok) { var dm = @Html.Raw(jsExpErrDelete); if (typeof showToast === 'function') showToast(dm); else alert(dm); return; }
                    const html = await res.text();
                    const content = document.getElementById('expenseOffcanvasContent');
                    content.innerHTML = html;
                    const offcanvasEl = document.getElementById('expenseOffcanvas');
                    const bsOff = new bootstrap.Offcanvas(offcanvasEl);
                    bsOff.show();
                    return;
                }
            });

            // Receipt preview modal
            var receiptModal = document.getElementById('receiptPreviewModal');
            var receiptContent = document.getElementById('receiptPreviewContent');
            var receiptDownload = document.getElementById('receiptPreviewDownload');
            function openReceiptPreview(expenseId) {
                if (!receiptModal || !receiptContent) return;
                var url = '@Url.Action("Receipt", "Expense")/' + expenseId;
                receiptContent.innerHTML = '<div class="d-flex align-items-center justify-content-center py-5"><div class="spinner-border text-light" role="status"></div></div>';
                receiptDownload.href = url;
                receiptDownload.style.display = 'inline-block';
                var m = new bootstrap.Modal(receiptModal);
                m.show();
                var xhr = new XMLHttpRequest();
                xhr.open('GET', url);
                xhr.responseType = 'blob';
                xhr.onload = function() {
                    if (xhr.status !== 200) {
                        receiptContent.innerHTML = '<p class="text-light py-5">' + @Html.Raw(jsExpErrReceipt) + '</p>';
                        return;
                    }
                    var blob = xhr.response;
                    var contentType = xhr.getResponseHeader('Content-Type') || '';
                    var isPdf = contentType.indexOf('pdf') !== -1;
                    if (isPdf) {
                        receiptContent.innerHTML = '<iframe src="' + url + '" style="width:100%;height:500px;border:none;" title="@L["Exp_ReceiptPdfTitle"]"></iframe>';
                    } else {
                        var reader = new FileReader();
                        reader.onload = function() {
                            receiptContent.innerHTML = '<img src="' + reader.result + '" alt="@L["Exp_ReceiptModalTitle"]" style="max-width:100%;max-height:70vh;object-fit:contain;" />';
                        };
                        reader.readAsDataURL(blob);
                    }
                };
                xhr.onerror = function() {
                    receiptContent.innerHTML = '<p class="text-light py-5">' + @Html.Raw(jsExpErrReceipt) + '</p>';
                };
                xhr.send();
            }
            document.querySelector('#expenseTable')?.addEventListener('click', function(e) {
                var btn = e.target.closest('.btn-receipt-preview');
                if (btn) {
                    e.preventDefault();
                    var id = btn.getAttribute('data-expense-id');
                    if (id) openReceiptPreview(id);
                }
            });
            document.querySelector('#expenseOffcanvasContent')?.addEventListener('click', function(e) {
                var btn = e.target.closest('.btn-preview-receipt');
                if (btn) {
                    e.preventDefault();
                    var id = btn.getAttribute('data-expense-id');
                    if (id) openReceiptPreview(id);
                }
            });
        })();
    </script>
}