@model (string? DisplayName, string? ProfileImagePath)
@using Microsoft.AspNetCore.Identity
@using FinanceApp.Infrastructure.Identity
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    var initials = string.IsNullOrWhiteSpace(Model.DisplayName)
        ? "?"
        : Model.DisplayName!.Trim().Substring(0, 1).ToUpperInvariant();
    var displayName = Model.DisplayName ?? User.Identity?.Name ?? "User";
    <li class="nav-item dropdown position-relative">
        <a class="navbar-avatar-btn dropdown-toggle d-flex align-items-center"
           href="#" id="navbarProfileDropdown" role="button"
           data-bs-toggle="dropdown" data-bs-boundary="viewport"
           data-bs-offset="0,0" aria-expanded="false"
           aria-label="Open profile menu"
           title="@displayName">
            @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
            {
                <img src="@Model.ProfileImagePath" alt="@displayName" class="navbar-avatar-img" />
            }
            else
            {
                <span class="navbar-avatar-initial" aria-hidden="true">@initials</span>
            }
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarProfileDropdown">
            <li class="dropdown-header px-3 py-2">
                <div class="fw-600 text-dark" style="font-size:.875rem;">@displayName</div>
            </li>
            <li><hr class="dropdown-divider my-1" /></li>
            <li>
                <a class="dropdown-item" asp-area="" asp-controller="Profile" asp-action="Edit">
                    <i class="bi bi-person-gear me-2"></i>Edit profile
                </a>
            </li>
            <li><hr class="dropdown-divider my-1" /></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                    <button type="submit" class="dropdown-item text-danger" aria-label="Log out">
                        <i class="bi bi-box-arrow-right me-2"></i>Sign out
                    </button>
                </form>
            </li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
}
</ul>
