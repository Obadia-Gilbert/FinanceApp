@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var title = ViewData["Title"] as string ?? "FinanceApp – Personal Finance & Budget Tracker";
    var metaDescription = ViewData["MetaDescription"] as string ?? "Track expenses, manage budgets, and get insights with FinanceApp. Free personal finance and budget tracker.";
    var canonicalUrl = ViewData["CanonicalUrl"] as string;
    var ogImage = ViewData["OgImage"] as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title</title>
    <meta name="description" content="@metaDescription" />
    @if (!string.IsNullOrEmpty(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
    }
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@title" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@(canonicalUrl ?? "")" />
    @if (!string.IsNullOrEmpty(ogImage))
    {
        <meta property="og:image" content="@ogImage" />
    }
    <meta property="og:locale" content="en_US" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@title" />
    <meta name="twitter:description" content="@metaDescription" />

    <link rel="icon" type="image/png" href="@Url.Content("~/financeapp-logo.png")" />
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/dark-mode.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    @* JSON-LD for SEO *@
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "WebApplication",
      "name": "FinanceApp",
      "description": "Track expenses, manage budgets, and get insights. Free personal finance and budget tracker.",
      "url": "@(canonicalUrl ?? "")",
      "applicationCategory": "FinanceApplication",
      "offers": { "@@type": "Offer", "price": "0", "priceCurrency": "USD" }
    }
    </script>
    @await RenderSectionAsync("Head", required: false)
</head>
<body data-theme="light" class="landing-body">

    <header class="landing-header">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Landing" asp-action="Index">
                    <img src="~/financeapp-logo.png" alt="FinanceApp" width="32" height="32" class="rounded" />
                    <span>FinanceApp</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#landingNav" aria-controls="landingNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="landingNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-2 gap-lg-3">
                        <li class="nav-item"><a class="nav-link" href="#features">Features</a></li>
                        <li class="nav-item"><a class="nav-link" href="#how-it-works">How it works</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-primary btn-sm px-3" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Home/Index">Sign in</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-primary btn-sm px-3" asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="/Home/Index">Get started free</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="landing-main">
        @RenderBody()
    </main>

    <footer class="landing-footer">
        <div class="container">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 py-4">
                <div class="d-flex align-items-center gap-2">
                    <img src="~/financeapp-logo.png" alt="FinanceApp" width="24" height="24" class="rounded" />
                    <span class="fw-semibold">FinanceApp</span>
                </div>
                <div class="d-flex flex-wrap align-items-center justify-content-center gap-3 small">
                    <a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy</a>
                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Home/Index" class="text-muted text-decoration-none">Sign in</a>
                    <span class="text-muted">&copy; @DateTime.Now.Year FinanceApp</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const body = document.body;
            const saved = localStorage.getItem('theme') || 'light';
            body.setAttribute('data-theme', saved);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
