@using System.Globalization
@{
    var current = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentLabel = current switch
    {
        "sw" => L["Lang_Swahili"].Value,
        "es" => L["Lang_Spanish"].Value,
        _ => L["Lang_English"].Value
    };
}
<div class="dropdown">
    <button class="btn btn-sm btn-outline-secondary dropdown-toggle d-flex align-items-center gap-1"
            type="button" id="langMenu" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false"
            title="@L["Lang_Language"]">
        <i class="bi bi-translate"></i>
        <span class="d-none d-sm-inline">@currentLabel</span>
    </button>
    <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="langMenu">
        <li>
            <a class="dropdown-item @(current == "en" ? "active" : null)"
               asp-controller="Language" asp-action="Set" asp-route-culture="en" asp-route-returnUrl="@returnUrl">@L["Lang_English"]</a>
        </li>
        <li>
            <a class="dropdown-item @(current == "sw" ? "active" : null)"
               asp-controller="Language" asp-action="Set" asp-route-culture="sw" asp-route-returnUrl="@returnUrl">@L["Lang_Swahili"]</a>
        </li>
        <li>
            <a class="dropdown-item @(current == "es" ? "active" : null)"
               asp-controller="Language" asp-action="Set" asp-route-culture="es" asp-route-returnUrl="@returnUrl">@L["Lang_Spanish"]</a>
        </li>
    </ul>
</div>
