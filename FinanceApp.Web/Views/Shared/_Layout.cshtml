<!DOCTYPE html>
@using System.Text.Json
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var showShell = !path.Contains("/identity/account/login") && !path.Contains("/identity/account/register") && !path.Contains("/identity/account/forgotpassword") && !path.Contains("/identity/account/externallogin") && !path.Contains("/home/privacy");
}
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinanceApp</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/financeapp-logo.png")" />
    <script type="importmap"></script>
    <!-- Antiforgery token for AJAX POSTs -->
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/dark-mode.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinanceApp.Web.styles.css" asp-append-version="true" />
</head>
<body data-theme="light">

    <!-- ── Fixed top navbar ─────────────────────────────────────── -->
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-light navbar-modern">
            <div class="container-fluid px-2 px-sm-3">
                <!-- Brand / Logo: landing when not signed in, dashboard when signed in -->
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="@(User.Identity?.IsAuthenticated == true ? "Home" : "Landing")" asp-action="Index">
                    <img src="~/financeapp-logo.png" alt="FinanceApp Logo" width="26" height="26" style="border-radius:6px; flex-shrink:0;" />
                    <span class="d-none d-sm-inline navbar-brand-text">FinanceApp</span>
                </a>

                <!-- Right-side actions -->
                <div class="d-flex align-items-center gap-1 ms-auto">
                    @if (showShell)
                    {
                        <div class="d-none d-md-block"><partial name="_LanguageSwitcher" /></div>
                    }
                    <button id="themeToggle" class="theme-toggle navbar-icon-btn d-none d-md-inline-flex"
                            title="@L["Nav_ToggleTheme"]" aria-label="@L["Nav_ToggleTheme"]">
                        <i class="bi bi-moon"></i>
                    </button>
                    @if (showShell)
                    {
                        <div class="d-inline-block" id="notificationDropdownWrap">
                        <div class="dropdown dropdown-notification d-none d-md-block position-relative" id="notificationDropdown">
                            <button class="navbar-icon-btn dropdown-toggle position-relative" type="button" id="notificationBell" data-bs-toggle="dropdown" data-bs-auto-close="outside" data-bs-display="static" data-bs-boundary="viewport" data-bs-offset="0,4" aria-expanded="false" aria-label="@L["Nav_Notifications"]">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light" id="notificationBadge" style="display: none; font-size: 0.65rem;">0</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end shadow notification-dropdown" style="min-width: 320px; max-width: 360px; padding: 0;" aria-labelledby="notificationBell">
                                <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-light">
                                    <span class="fw-semibold">@L["Notif_DropdownTitle"]</span>
                                    <button type="button" class="btn btn-link btn-sm p-0 text-decoration-none" id="notificationMarkAllRead" title="@L["Notif_MarkAllTitle"]">@L["Notif_MarkAllRead"]</button>
                                </div>
                                <div class="px-3 py-3 text-center text-muted small" id="notificationListLoading">@L["Common_Loading"]</div>
                                <ul class="list-group list-group-flush list-unstyled mb-0" id="notificationList" style="max-height: 280px; overflow-y: auto;"></ul>
                                <div class="text-center py-2 border-top"><a asp-controller="Notification" asp-action="Index" class="small">@L["Notif_ViewAll"]</a></div>
                            </div>
                        </div>
                        </div>
                        <div class="d-none d-md-block">
                            @await Component.InvokeAsync("UserProfile")
                        </div>
                        <!-- Hamburger: mobile only -->
                        <button class="navbar-icon-btn d-md-none" type="button"
                                data-bs-toggle="collapse" data-bs-target="#sidebarCollapse"
                                aria-controls="sidebarCollapse" aria-expanded="false"
                                aria-label="@L["Aria_Menu"]" title="@L["Aria_Menu"]">
                            <i class="bi bi-list fs-5"></i>
                        </button>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- ── App shell: sidebar + scrollable main ─────────────────── -->
    <div class="app-shell">
        @if (showShell)
        {
            <!-- Fixed sidebar (desktop) / overlay (mobile) -->
            <aside class="app-sidebar collapse d-md-block" id="sidebarCollapse">
                @await Html.PartialAsync("_Sidebar")
            </aside>

            <!-- Scrollable main content -->
            <main class="app-main">
                <div class="app-main-content">
                    @RenderBody()
                </div>

                <footer class="app-footer border-top mt-auto">
                    <div class="container-fluid px-3 px-md-4 py-3">
                        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-2">
                            <div class="d-flex align-items-center gap-2">
                                <img src="~/financeapp-logo.png" alt="FinanceApp" width="22" height="22" class="rounded-1" />
                                <span class="fw-semibold">FinanceApp</span>
                            </div>
                            <div class="d-flex flex-wrap align-items-center gap-3 small">
                                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link">@L["Nav_Privacy"]</a>
                                <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-link">@L["Nav_Dashboard"]</a>
                                <span class="text-muted">&copy; @DateTime.Now.Year FinanceApp</span>
                            </div>
                        </div>
                    </div>
                </footer>
            </main>
        }
        else
        {
            <!-- Auth pages: full-width, no sidebar -->
            <main class="app-main app-main--full">
                <div class="app-main-content">
                    @RenderBody()
                </div>
            </main>
        }
    </div>

    <!-- Toast container (stays fixed regardless of scroll) -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

    <script>
        window.__financeAppI18n = window.__financeAppI18n || {};
        window.__financeAppI18n.notifEmpty = @Html.Raw(JsonSerializer.Serialize(L["Notif_NoneDropdown"].Value));
        window.__financeAppI18n.notifMarkRead = @Html.Raw(JsonSerializer.Serialize(L["Notif_MarkOneTitle"].Value));
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/datatables.net@1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/datatables.net-bs5@1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Theme toggle
        (function () {
            const body    = document.body;
            const toggles = document.querySelectorAll('.theme-toggle');
            const iconClass = (theme) => theme === 'dark' ? 'bi bi-sun' : 'bi bi-moon';

            function setTheme(theme) {
                body.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);
                toggles.forEach(t => {
                    const icon = t.querySelector('i');
                    if (icon) icon.className = iconClass(theme);
                });
            }

            const saved = localStorage.getItem('theme') || 'light';
            setTheme(saved);
            toggles.forEach(t => t.addEventListener('click', function () {
                setTheme(body.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
            }));
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
