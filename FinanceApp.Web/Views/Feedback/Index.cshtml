@model IEnumerable<FinanceApp.Web.Models.FeedbackListViewModel>
@using FinanceApp.Domain.Enums
@{
    ViewData["Title"] = "Feedback";
    int pageNumber = ViewBag.PageNumber ?? 1;
    int pageSize = ViewBag.PageSize ?? 15;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
}

<div class="mb-4">
    <h1 class="visually-hidden">Feedback</h1>
    <p class="page-subtitle mb-3">Ask questions, share suggestions, or leave a comment. Our team reviews all feedback.</p>
    <div class="d-flex gap-2 mb-3">
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-chat-square-text"></i> Submit feedback
        </a>
    </div>
</div>

@if (TempData["FeedbackSuccess"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["FeedbackSuccess"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-chat-square-text display-4 d-block mb-2"></i>
            <p class="mb-1">You haven't submitted any feedback yet.</p>
            <p class="small mb-0">Questions, suggestions, and comments help us improve the app for everyone.</p>
            <a asp-action="Create" class="btn btn-outline-primary mt-3"><i class="bi bi-plus-lg me-1"></i>Submit feedback</a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Subject</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-nowrap">@item.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    @switch (item.Type)
                                    {
                                        case FeedbackType.Question:
                                            <span class="badge bg-info">Question</span>
                                            break;
                                        case FeedbackType.Suggestion:
                                            <span class="badge bg-primary">Suggestion</span>
                                            break;
                                        case FeedbackType.Comment:
                                            <span class="badge bg-secondary">Comment</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@item.Type</span>
                                            break;
                                    }
                                </td>
                                <td>@(item.Subject ?? "—")</td>
                                <td class="text-truncate" style="max-width: 280px;" title="@item.Message">@item.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3" aria-label="Feedback pagination">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber - 1)" asp-route-pageSize="@pageSize">‹ Prev</a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == pageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@p" asp-route-pageSize="@pageSize">@p</a>
                    </li>
                }
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber + 1)" asp-route-pageSize="@pageSize">Next ›</a>
                </li>
            </ul>
            <p class="text-center small text-muted mt-2">Page @pageNumber of @totalPages (@totalItems total)</p>
        </nav>
    }
}
