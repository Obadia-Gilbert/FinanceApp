@model FinanceApp.Web.Models.FeedbackCreateViewModel
@{
    ViewData["Title"] = "Submit feedback";
    var types = ViewBag.FeedbackTypes as IEnumerable<FinanceApp.Domain.Enums.FeedbackType> ?? Enum.GetValues<FinanceApp.Domain.Enums.FeedbackType>();
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <h1 class="h3 mb-2">Submit feedback</h1>
            <p class="text-muted small mb-4">Ask a question, suggest an improvement, or leave a comment. Your feedback is visible only to our team and helps us improve the app for everyone.</p>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Type</label>
                            <select asp-for="Type" class="form-select" required>
                                @foreach (var t in types)
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">Subject <span class="text-muted">(optional)</span></label>
                            <input asp-for="Subject" class="form-control" placeholder="e.g. Feature request: dark mode" maxlength="200" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Message" class="form-label">Your message</label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Describe your question, suggestion, or comment..." maxlength="4000" required></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                            <small class="text-muted">Max 4000 characters.</small>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-1"></i>Submit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
