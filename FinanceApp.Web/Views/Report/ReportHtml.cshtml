@model FinanceApp.Application.Common.MonthlyReportResult
@{
    Layout = null;
    var monthNames = new[] { "", "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Monthly Report - @Model.MonthName - FinanceApp</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; color: #333; }
        h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
        .muted { color: #666; font-size: 0.875rem; }
        .summary { display: flex; gap: 1.5rem; flex-wrap: wrap; margin: 1.5rem 0; }
        .summary-box { padding: 1rem; background: #f5f5f5; border-radius: 8px; min-width: 180px; }
        .summary-box.over { background: #fee; }
        .summary-box .label { font-size: 0.75rem; color: #666; text-transform: uppercase; }
        .summary-box .value { font-size: 1.25rem; font-weight: 600; }
        table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
        th, td { padding: 0.5rem 0.75rem; text-align: left; border-bottom: 1px solid #eee; }
        th { font-size: 0.75rem; color: #666; text-transform: uppercase; }
        .text-end { text-align: right; }
        .over-row { background: #fee; }
        ul { list-style: none; padding: 0; margin: 1rem 0; }
        ul li { padding: 0.5rem 0; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; }
        .footer { margin-top: 2rem; font-size: 0.75rem; color: #999; }
    </style>
</head>
<body>
    <h1>@Model.MonthName</h1>
    <p class="muted">FinanceApp monthly report — generated @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>

    <div class="summary">
        <div class="summary-box">
            <div class="label">Total spent</div>
            <div class="value">@Model.TotalSpent.ToString("N0") @Model.Currency</div>
        </div>
        <div class="summary-box">
            <div class="label">Total income</div>
            <div class="value" style="color: #0d6efd;">@Model.TotalIncome.ToString("N0") @Model.Currency</div>
        </div>
        <div class="summary-box">
            <div class="label">Net cash flow</div>
            <div class="value" style="color: @(Model.NetCashFlow >= 0 ? "#198754" : "#dc3545");">@Model.NetCashFlow.ToString("N0") @Model.Currency</div>
        </div>
        @if (Model.GlobalBudgetAmount.HasValue)
        {
            <div class="summary-box @(Model.IsOverGlobalBudget ? "over" : "")">
                <div class="label">Monthly budget</div>
                <div class="value">@Model.GlobalBudgetAmount.Value.ToString("N0") @Model.Currency</div>
                @if (Model.GlobalBudgetRemaining.HasValue)
                {
                    <div class="muted" style="margin-top: 0.25rem;">
                        @(Model.IsOverGlobalBudget ? "Exceeded by " + (-Model.GlobalBudgetRemaining.Value).ToString("N0") : "Left: " + Model.GlobalBudgetRemaining.Value.ToString("N0")) @Model.Currency
                    </div>
                }
            </div>
        }
    </div>

    @if (Model.CategoryLines.Any())
    {
        <h2 style="font-size: 1rem;">By category</h2>
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th class="text-end">Spent</th>
                    <th class="text-end">Budget</th>
                    <th class="text-end">Left</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.CategoryLines)
                {
                    <tr class="@(line.IsOverBudget ? "over-row" : "")">
                        <td>@line.CategoryName</td>
                        <td class="text-end">@line.Spent.ToString("N0") @Model.Currency</td>
                        <td class="text-end">@(line.BudgetAmount.HasValue ? line.BudgetAmount.Value.ToString("N0") : "—")</td>
                        <td class="text-end">@(line.Remaining.HasValue ? (line.IsOverBudget ? "Over" : line.Remaining.Value.ToString("N0")) : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Model.TopExpenses.Any())
    {
        <h2 style="font-size: 1rem;">Top expenses</h2>
        <ul>
            @foreach (var e in Model.TopExpenses.Take(15))
            {
                <li>
                    <span>@(string.IsNullOrEmpty(e.Description) ? "Expense" : e.Description) — @e.CategoryName · @e.Date.ToString("MMM d")</span>
                    <span>@e.Amount.ToString("N0") @e.Currency</span>
                </li>
            }
        </ul>
    }

    <p class="footer">FinanceApp — monthly report. You can save this page (File → Save As) to keep a copy.</p>
</body>
</html>
