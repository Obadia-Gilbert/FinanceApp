@model FinanceApp.Web.Models.RecurringTemplateCreateViewModel
@using FinanceApp.Domain.Enums
@{
    ViewData["Title"] = "Add recurring";
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account>;
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category>;
    var currencies = ViewBag.Currencies as IEnumerable<Currency>;
    var frequencies = ViewBag.Frequencies as IEnumerable<RecurrenceFrequency>;
}

<div class="mb-4">
    <h1 class="h4">Add recurring transaction</h1>
    <p class="text-muted">A transaction will be created automatically on each run date (e.g. monthly salary).</p>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Type" class="form-label">Type</label>
                    <select asp-for="Type" class="form-select">
                        <option value="@TransactionType.Income">Income</option>
                        <option value="@TransactionType.Expense">Expense</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="AccountId" class="form-label">Account</label>
                    <select asp-for="AccountId" class="form-select" required>
                        <option value="">-- Select --</option>
                        @if (accounts != null)
                        {
                            @foreach (var a in accounts)
                            {
                                <option value="@a.Id">@a.Name (@a.Currency)</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="AccountId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label">Category <span class="text-muted">(optional)</span></label>
                    <select asp-for="CategoryId" class="form-select">
                        <option value="">-- None --</option>
                        @if (categories != null)
                        {
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Amount" class="form-label">Amount</label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Currency" class="form-label">Currency</label>
                    <select asp-for="Currency" class="form-select">
                        @if (currencies != null)
                        {
                            @foreach (var c in currencies)
                            {
                                <option value="@c">@c</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Frequency" class="form-label">Frequency</label>
                    <select asp-for="Frequency" class="form-select">
                        @if (frequencies != null)
                        {
                            @foreach (var f in frequencies)
                            {
                                <option value="@f">@f</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Interval" class="form-label">Every (e.g. 2 = every 2 weeks/months/years)</label>
                    <input asp-for="Interval" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Interval" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="StartDate" class="form-label">Start date</label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="EndDate" class="form-label">End date <span class="text-muted">(optional)</span></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                </div>
                <div class="col-12">
                    <label asp-for="Note" class="form-label">Note</label>
                    <input asp-for="Note" class="form-control" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create recurring</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
<partial name="_ValidationScriptsPartial" />
