@model IEnumerable<FinanceApp.Web.Models.RecurringTemplateListViewModel>
@using FinanceApp.Domain.Enums
@{
    ViewData["Title"] = "Recurring";
    int pageNumber = ViewBag.PageNumber ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
}

<div class="mb-4">
    <h1 class="visually-hidden">Recurring transactions</h1>
    <p class="page-subtitle mb-3">Templates that automatically create income or expense transactions on a schedule.</p>
    <div class="d-flex gap-2 mb-3">
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Add recurring</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No recurring templates. Click <strong>Add recurring</strong> to create one (e.g. monthly salary, rent).
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Account</th>
                            <th>Category</th>
                            <th class="text-end">Amount</th>
                            <th>Frequency</th>
                            <th>Next run</th>
                            <th>End date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    <span class="@(r.Type == TransactionType.Income ? "text-success" : "text-danger")">
                                        <i class="bi @(r.Type == TransactionType.Income ? "bi-arrow-down-circle" : "bi-arrow-up-circle") me-1"></i>@r.Type
                                    </span>
                                </td>
                                <td>@r.AccountName</td>
                                <td>@(r.CategoryName ?? "—")</td>
                                <td class="text-end @(r.Type == TransactionType.Income ? "text-success" : "text-danger")">
                                    @(r.Type == TransactionType.Income ? "+" : "−") @r.Currency @r.Amount.ToString("N2")
                                </td>
                                <td>Every @(r.Interval > 1 ? r.Interval + " " : "")@r.Frequency.ToString().ToLowerInvariant()</td>
                                <td class="text-nowrap">@r.NextRunDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-nowrap">@(r.EndDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td class="text-nowrap">
                                    <form method="post" asp-action="Deactivate" asp-route-id="@r.Id" style="display:inline" onsubmit="return confirm('Pause this recurring template?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Pause</button>
                                    </form>
                                    <form method="post" asp-action="Delete" asp-route-id="@r.Id" style="display:inline" onsubmit="return confirm('Delete this recurring template?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3" aria-label="Recurring pagination">
            <ul class="pagination justify-content-center mb-0">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber - 1)">‹ Prev</a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == pageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@p">@p</a>
                    </li>
                }
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber + 1)">Next ›</a>
                </li>
            </ul>
        </nav>
    }
}
