@model FinanceApp.Web.Models.TransactionCreateViewModel

@{
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account> ?? Enumerable.Empty<FinanceApp.Domain.Entities.Account>();
    var categories = ViewBag.Categories as IEnumerable<FinanceApp.Domain.Entities.Category> ?? Enumerable.Empty<FinanceApp.Domain.Entities.Category>();
}

<form asp-action="Create" asp-controller="Transaction" method="post" class="p-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="AccountId" class="form-label">@L["Lbl_Account"]</label>
        <select asp-for="AccountId" class="form-select">
            <option value="">@L["Tx_SelectAccount"]</option>
            @foreach (var a in accounts)
            {
                <option value="@a.Id">@a.Name (@a.Currency)</option>
            }
        </select>
        <span asp-validation-for="AccountId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label">@L["Lbl_Type"]</label>
        <div class="btn-group w-100" role="group">
            <input type="radio" name="Type" id="typeIncome" value="Income" class="btn-check" autocomplete="off"
                   @(Model.Type == FinanceApp.Domain.Enums.TransactionType.Income ? "checked" : "") />
            <label class="btn btn-outline-success" for="typeIncome"><i class="bi bi-arrow-down-circle me-1"></i>@L["Tx_TypeIncome"]</label>

            <input type="radio" name="Type" id="typeExpense" value="Expense" class="btn-check" autocomplete="off"
                   @(Model.Type == FinanceApp.Domain.Enums.TransactionType.Expense ? "checked" : "") />
            <label class="btn btn-outline-danger" for="typeExpense"><i class="bi bi-arrow-up-circle me-1"></i>@L["Tx_TypeExpense"]</label>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">Amount</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" placeholder="0.00" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            @foreach (var c in Enum.GetValues(typeof(FinanceApp.Domain.Enums.Currency)))
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Date" class="form-label">@L["Lbl_Date"]</label>
        <input asp-for="Date" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">@L["Lbl_Category"] <span class="text-muted fw-normal">@L["Tx_CategoryOptional"]</span></label>
        <select asp-for="CategoryId" class="form-select" id="transactionCategorySelect">
            <option value="">@L["Tx_None"]</option>
            @foreach (var cat in categories)
            {
                <option value="@cat.Id" data-type="@cat.Type">@cat.Name</option>
            }
        </select>
        <small class="text-muted">@L["Tx_CategoryFilterHint"]</small>
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label">@L["Lbl_Note"] <span class="text-muted fw-normal">@L["Exp_ReceiptOptional"]</span></label>
        <input asp-for="Note" class="form-control" placeholder="@L["Tx_NotePlaceholder"]" />
    </div>

    <div class="mb-3 form-check">
        <input asp-for="IsRecurring" class="form-check-input" type="checkbox" />
        <label asp-for="IsRecurring" class="form-check-label">@L["Tx_Recurring"]</label>
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i>@L["Tx_SaveTransaction"]
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />
<script>
(function() {
    var sel = document.getElementById('transactionCategorySelect');
    var typeIncome = document.getElementById('typeIncome');
    var typeExpense = document.getElementById('typeExpense');
    if (!sel || !typeIncome || !typeExpense) return;
    function filterCategories() {
        var type = typeIncome.checked ? 'Income' : (typeExpense.checked ? 'Expense' : null);
        var allowed = type === 'Income' ? ['Income', 'Both'] : (type === 'Expense' ? ['Expense', 'Both'] : []);
        Array.from(sel.options).forEach(function(opt) {
            if (opt.value === '') { opt.style.display = ''; return; }
            var t = opt.getAttribute('data-type');
            opt.style.display = (allowed.length === 0 || (t && allowed.indexOf(t) !== -1)) ? '' : 'none';
        });
        if (sel.value && sel.selectedIndex >= 0) {
            var chosen = sel.options[sel.selectedIndex];
            if (chosen.style.display === 'none') sel.value = '';
        }
    }
    typeIncome.addEventListener('change', filterCategories);
    typeExpense.addEventListener('change', filterCategories);
    filterCategories();
})();
</script>
