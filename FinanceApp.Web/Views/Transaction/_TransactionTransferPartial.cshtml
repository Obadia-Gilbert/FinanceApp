@model FinanceApp.Web.Models.TransactionTransferViewModel

@{
    var accounts = ViewBag.Accounts as IEnumerable<FinanceApp.Domain.Entities.Account> ?? Enumerable.Empty<FinanceApp.Domain.Entities.Account>();
}

<form asp-action="Transfer" asp-controller="Transaction" method="post" class="p-3">
    @Html.AntiForgeryToken()

    <div class="alert alert-info py-2 small mb-3">
        <i class="bi bi-arrow-left-right me-1"></i>
        @L["Tx_TransferBlurb"]
    </div>

    <div class="mb-3">
        <label asp-for="FromAccountId" class="form-label">@L["Lbl_FromAccount"]</label>
        <select asp-for="FromAccountId" class="form-select">
            <option value="">@L["Tx_SelectAccount"]</option>
            @foreach (var a in accounts)
            {
                <option value="@a.Id">@a.Name (@a.Currency)</option>
            }
        </select>
        <span asp-validation-for="FromAccountId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ToAccountId" class="form-label">@L["Lbl_ToAccount"]</label>
        <select asp-for="ToAccountId" class="form-select">
            <option value="">@L["Tx_SelectAccount"]</option>
            @foreach (var a in accounts)
            {
                <option value="@a.Id">@a.Name (@a.Currency)</option>
            }
        </select>
        <span asp-validation-for="ToAccountId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Amount" class="form-label">@L["Table_Amount"]</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" placeholder="0.00" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Currency" class="form-label">@L["Lbl_Currency"]</label>
        <select asp-for="Currency" class="form-select">
            @foreach (var c in Enum.GetValues(typeof(FinanceApp.Domain.Enums.Currency)))
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Date" class="form-label">@L["Lbl_Date"]</label>
        <input asp-for="Date" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="Date" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Note" class="form-label">@L["Lbl_Note"] <span class="text-muted fw-normal">@L["Exp_ReceiptOptional"]</span></label>
        <input asp-for="Note" class="form-control" placeholder="@L["Tx_TransferNotePlaceholder"]" />
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">@L["Common_Cancel"]</button>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-arrow-left-right me-1"></i>@L["Tx_Transfer"]
        </button>
    </div>
</form>

<partial name="_ValidationScriptsPartial" />
