@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Password reset";
}

<div class="container-fluid auth-page">
    <div class="row justify-content-center py-3 py-md-4">
        <div class="col-12 col-sm-10 col-md-8 col-lg-6 col-xl-5">
            <div class="card shadow-lg border-0 rounded-lg auth-card">
                <div class="card-body p-4 auth-card-body text-center">
                    <div class="mb-3">
                        <i class="bi bi-shield-check text-success" style="font-size: 2.5rem;"></i>
                    </div>
                    <h1 class="h3 fw-bold mb-2">Password reset complete</h1>
                    <p class="text-muted mb-4">
                        Your password has been updated. You can now sign in with your new password.
                    </p>
                    <a asp-page="./Login" class="btn btn-primary w-100 fw-600">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
