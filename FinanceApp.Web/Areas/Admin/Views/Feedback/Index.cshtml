@model IEnumerable<FinanceApp.Domain.Entities.UserFeedback>
@using FinanceApp.Domain.Enums
@{
    ViewData["Title"] = "User feedback";
    var userEmails = ViewBag.UserEmails as Dictionary<string, string> ?? new Dictionary<string, string>();
    int pageNumber = ViewBag.PageNumber ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    var statusFilter = ViewBag.StatusFilter as FeedbackStatus?;
    var typeFilter = ViewBag.TypeFilter as FeedbackType?;
}

<div class="mb-4">
    <h1 class="visually-hidden">User feedback</h1>
    <p class="page-subtitle mb-3">Questions, suggestions, and comments from users. Review and add internal notes.</p>

    <form method="get" asp-action="Index" class="row g-2 mb-3">
        <div class="col-auto">
            <label class="form-label visually-hidden">Status</label>
            <select name="status" class="form-select form-select-sm" style="width: auto;">
                <option value="" selected="@(!statusFilter.HasValue)">All statuses</option>
                @foreach (FeedbackStatus s in ViewBag.FeedbackStatuses)
                {
                    <option value="@((int)s)" selected="@(statusFilter == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label visually-hidden">Type</label>
            <select name="type" class="form-select form-select-sm" style="width: auto;">
                <option value="" selected="@(!typeFilter.HasValue)">All types</option>
                @foreach (FeedbackType t in ViewBag.FeedbackTypes)
                {
                    <option value="@((int)t)" selected="@(typeFilter == t)">@t</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Filter</button>
        </div>
    </form>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-chat-square-text display-4 d-block mb-2"></i>
            <p class="mb-0">No feedback matches the current filters.</p>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>User</th>
                            <th>Type</th>
                            <th>Subject</th>
                            <th>Message</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var email = userEmails.GetValueOrDefault(item.UserId, item.UserId);
                            <tr class="@(item.Status == FeedbackStatus.New ? "table-warning" : "")">
                                <td class="text-nowrap">@item.CreatedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="small">@email</td>
                                <td>
                                    @switch (item.Type)
                                    {
                                        case FeedbackType.Question:
                                            <span class="badge bg-info">Question</span>
                                            break;
                                        case FeedbackType.Suggestion:
                                            <span class="badge bg-primary">Suggestion</span>
                                            break;
                                        case FeedbackType.Comment:
                                            <span class="badge bg-secondary">Comment</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@item.Type</span>
                                            break;
                                    }
                                </td>
                                <td>@(item.Subject ?? "—")</td>
                                <td class="text-truncate" style="max-width: 220px;" title="@item.Message">@item.Message</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case FeedbackStatus.New:
                                            <span class="badge bg-warning text-dark">New</span>
                                            break;
                                        case FeedbackStatus.Read:
                                            <span class="badge bg-success">Read</span>
                                            break;
                                        case FeedbackStatus.Archived:
                                            <span class="badge bg-secondary">Archived</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@item.Status</span>
                                            break;
                                    }
                                </td>
                                <td class="text-nowrap">
                                    <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <p class="small text-muted mb-0">Page @pageNumber of @totalPages (@totalItems total)</p>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber - 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-status="@((int?)statusFilter)" asp-route-type="@((int?)typeFilter)">‹ Prev</a>
                </li>
                <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber + 1)" asp-route-pageSize="@ViewBag.PageSize" asp-route-status="@((int?)statusFilter)" asp-route-type="@((int?)typeFilter)">Next ›</a>
                </li>
            </ul>
        </nav>
    }
}
