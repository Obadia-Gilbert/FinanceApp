  <data name="Priv_Title" xml:space="preserve"><value>Privacy Policy</value></data>
  <data name="Priv_BadgeUpdated" xml:space="preserve"><value>Last updated: March 1, 2026</value></data>
  <data name="Priv_HeroLead" xml:space="preserve"><value>We believe your financial data belongs to you. This policy explains clearly what we collect, how we use it, and the controls you have over it.</value></data>
  <data name="Priv_TocContents" xml:space="preserve"><value>Contents</value></data>
  <data name="Priv_TocNavAria" xml:space="preserve"><value>Policy sections</value></data>
